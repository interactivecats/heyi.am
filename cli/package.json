{
  "name": "heyiam",
  "version": "0.1.0",
  "description": "Turn AI coding sessions into portfolio case studies",
  "type": "module",
  "bin": {
    "heyiam": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && cd app && npm run build",
    "dev": "npx concurrently \"npm:dev:api\" \"npm:dev:app\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:app": "cd app && npm run dev",
    "test": "cd app && npx vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "commander": "^13.1.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
