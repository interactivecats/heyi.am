<div class="heyiam-project carbon" data-render-version="2" data-template="carbon"{% if sessionBaseUrl %} data-session-base-url="{{ sessionBaseUrl }}"{% endif %} data-username="{{ user.username }}" data-project-slug="{{ project.slug }}">

  <h1 class="project-title" data-editable="title">{{ project.title }}</h1>

  {% render 'partials/_links', project: project %}

  {% render 'partials/_screenshot', project: project %}

  {% render 'partials/_narrative', narrative: project.narrative %}

  {%- comment -%} Stats grid (no leverage here) {%- endcomment -%}
  <div class="stat-grid" role="list" aria-label="Project statistics">
    <div class="stat-card" role="listitem">
      <div class="stat-card__label">Sessions</div>
      <div class="stat-card__value">{{ project.totalSessions }}</div>
    </div>
    <div class="stat-card" role="listitem">
      <div class="stat-card__label">Lines changed</div>
      <div class="stat-card__value">{{ project.totalLoc | formatLoc }}</div>
    </div>
    <div class="stat-card" role="listitem">
      <div class="stat-card__label">Files</div>
      <div class="stat-card__value">{{ project.totalFilesChanged }}</div>
    </div>
    {% if project.totalTokens %}
    <div class="stat-card" role="listitem">
      <div class="stat-card__label">Tokens</div>
      <div class="stat-card__value">{{ project.totalTokens | formatTokens }}</div>
    </div>
    {% endif %}
  </div>

  {%- comment -%} Leverage: horizontal strip below stat grid {%- endcomment -%}
  {% if efficiencyMultiplier %}
  <div class="carbon-leverage-strip" role="status" aria-label="Leverage multiplier: {{ efficiencyMultiplier }}">
    <div class="carbon-leverage-strip__left">
      <span class="carbon-leverage-strip__multiplier" style="color: var(--accent, #94a3b8);">{{ efficiencyMultiplier }}</span>
    </div>
    <div class="carbon-leverage-strip__divider" aria-hidden="true"></div>
    <div class="carbon-leverage-strip__right">
      <div class="carbon-leverage-strip__row">
        <span class="carbon-leverage-strip__label" style="opacity: 0.5;">you</span>
        <span class="carbon-leverage-strip__value" style="opacity: 0.5;">{{ project.totalDurationMinutes | formatDuration }}</span>
      </div>
      <div class="carbon-leverage-strip__row">
        <span class="carbon-leverage-strip__label" style="color: var(--accent, #94a3b8);">agents</span>
        <span class="carbon-leverage-strip__value" style="color: var(--accent, #94a3b8);">{{ project.totalAgentDurationMinutes | formatDuration }}</span>
      </div>
    </div>
    <div class="carbon-leverage-strip__bar" aria-hidden="true">
      <div class="carbon-leverage-strip__bar-fill" style="background: var(--accent, #94a3b8);"></div>
    </div>
  </div>
  {% else %}
  <div class="carbon-leverage-strip" role="status">
    <div class="carbon-leverage-strip__left">
      <span class="carbon-leverage-strip__multiplier">{{ project.totalDurationMinutes | formatDuration }}</span>
    </div>
  </div>
  {% endif %}

  {% render 'partials/_work-timeline', sessionsJson: sessionsJson %}

  {% render 'partials/_growth-chart', project: project, growthJson: growthJson %}

  <div class="two-col">
    {% render 'partials/_key-decisions', arc: arc %}
    {% render 'partials/_source-breakdown', sourceCounts: sourceCounts %}
  </div>

  {% render 'partials/_phases', arc: arc %}

  {% render 'partials/_skills', skills: project.skills %}

  {% render 'partials/_session-cards', featuredSessions: featuredSessions, sessionBaseUrl: sessionBaseUrl, totalSessionCount: sessions.size %}

  {% render 'partials/_footer', sessionBaseUrl: sessionBaseUrl %}

</div>
