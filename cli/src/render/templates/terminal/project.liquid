<div class="heyiam-project terminal" data-render-version="2" data-template="terminal"{% if sessionBaseUrl %} data-session-base-url="{{ sessionBaseUrl }}"{% endif %} data-session-suffix="{{ sessionSuffix }}" data-username="{{ user.username }}" data-project-slug="{{ project.slug }}">

  {%- comment -%} Prompt-style breadcrumb {%- endcomment -%}
  <div class="term-prompt">
    <span class="term-prompt__char">&#10095;</span>
    <span class="term-prompt__path"><a href="/{{ user.username }}">@{{ user.username }}</a>/{{ project.slug }}</span>
  </div>

  {%- comment -%} # Title {%- endcomment -%}
  <h1 class="term-heading" data-editable="title"># {{ project.title }}</h1>

  {%- comment -%} Links as $ open URL {%- endcomment -%}
  {% if project.repoUrl or project.projectUrl %}
  <div class="term-section term-links" data-editable="links">
    {% if project.repoUrl %}
    <div class="term-cmd">
      <span class="term-cmd__prefix">$</span> <span class="term-cmd__text">open</span> <a href="{{ project.repoUrl }}" target="_blank" rel="noopener noreferrer">{{ project.repoUrl | stripProtocol }}</a>
    </div>
    {% endif %}
    {% if project.projectUrl %}
    <div class="term-cmd">
      <span class="term-cmd__prefix">$</span> <span class="term-cmd__text">open</span> <a href="{{ project.projectUrl }}" target="_blank" rel="noopener noreferrer">{{ project.projectUrl | stripProtocol }}</a>
    </div>
    {% endif %}
  </div>
  {% endif %}

  {%- comment -%} Screenshot {%- endcomment -%}
  {% if project.screenshotUrl %}
  <div class="term-section term-screenshot" data-editable="screenshot">
    <div class="term-screenshot__chrome">
      <span class="term-screenshot__dots">&#9679; &#9679; &#9679;</span>
      <span class="term-screenshot__url">{{ project.slug }}</span>
    </div>
    <img src="{{ project.screenshotUrl }}" alt="Screenshot of {{ project.title }}" class="term-screenshot__img" loading="lazy" />
  </div>
  {% endif %}
  {% unless project.screenshotUrl %}
  <div data-editable="screenshot" class="screenshot-placeholder"></div>
  {% endunless %}

  {%- comment -%} Narrative {%- endcomment -%}
  {% if project.narrative != blank %}
  <div class="term-section">
    <div class="term-comment"># narrative</div>
    <blockquote class="term-blockquote">&gt; {{ project.narrative }}</blockquote>
  </div>
  {% endif %}

  {%- comment -%} Stats as tabular output {%- endcomment -%}
  <div class="term-section">
    <div class="term-comment"># stats</div>
    <table class="term-table">
      <tr>
        <td class="term-table__key">{{ durationLabel }}</td>
        <td class="term-table__val">{% if project.totalAgentDurationMinutes %}{{ project.totalDurationMinutes | formatDuration }} / {{ project.totalAgentDurationMinutes | formatDuration }}{% else %}{{ project.totalDurationMinutes | formatDuration }}{% endif %}</td>
      </tr>
      {% if efficiencyMultiplier %}
      <tr><td class="term-table__key">leverage</td><td class="term-table__val"><span class="term-accent">{{ efficiencyMultiplier }}</span></td></tr>
      {% endif %}
      <tr><td class="term-table__key">sessions</td><td class="term-table__val">{{ project.totalSessions }}</td></tr>
      <tr><td class="term-table__key">lines_changed</td><td class="term-table__val">{{ project.totalLoc | formatLoc }}</td></tr>
      <tr><td class="term-table__key">files</td><td class="term-table__val">{{ project.totalFilesChanged }}</td></tr>
      {% if project.totalTokens %}<tr><td class="term-table__key">tokens</td><td class="term-table__val">{{ project.totalTokens | formatTokens }}</td></tr>{% endif %}
    </table>
  </div>

  {%- comment -%} Work timeline chart {%- endcomment -%}
  {% if sessionsJson %}
  <div class="term-section">
    <div class="term-comment"># work timeline</div>
    <div data-work-timeline data-sessions='{{ sessionsJson | raw }}'></div>
  </div>
  {% endif %}

  {%- comment -%} Growth chart {%- endcomment -%}
  {% if growthJson %}
  <div class="term-section">
    <div class="term-comment"># growth</div>
    <div data-growth-chart data-project-slug="{{ project.slug }}" data-sessions='{{ growthJson | raw }}'></div>
  </div>
  {% endif %}

  {%- comment -%} Phases as git log style {%- endcomment -%}
  {% if arc.size > 0 %}
  <div class="term-section">
    <div class="term-comment"># git log --oneline --graph</div>
    <div class="term-git-log">
      {% for phase in arc %}
      <div class="term-git-log__entry">
        <span class="term-git-log__graph">{% if forloop.last %}&#9492;{% else %}&#9500;{% endif %}&#9472;</span>
        <span class="term-git-log__hash">{{ phase.phase | prepend: '0' | slice: -2, 2 }}</span>
        <span class="term-git-log__msg">{{ phase.title }}</span>
        <span class="term-git-log__desc term-dim">&mdash; {{ phase.description }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {%- comment -%} Skills {%- endcomment -%}
  {% if project.skills.size > 0 %}
  <div class="term-section">
    <div class="term-comment"># skills</div>
    <div class="term-inline-skills">
      {% for skill in project.skills %}
      <span class="term-skill-tag">{{ skill }}</span>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {%- comment -%} Source breakdown as table {%- endcomment -%}
  {% if sourceCounts.size > 0 %}
  <div class="term-section">
    <div class="term-comment"># source breakdown</div>
    <table class="term-table">
      <tr><td class="term-table__header">SOURCE</td><td class="term-table__header">COUNT</td></tr>
      {% for src in sourceCounts %}
      <tr><td class="term-table__key">{{ src.tool }}</td><td class="term-table__val">{{ src.count }}</td></tr>
      {% endfor %}
    </table>
  </div>
  {% endif %}

  {%- comment -%} Sessions as numbered entries {%- endcomment -%}
  {% if featuredSessions.size > 0 %}
  <div class="term-section">
    <div class="term-comment"># sessions ({{ project.totalSessions }} total)</div>
    {% for s in featuredSessions %}
    <div class="term-session-entry">
      {% if sessionBaseUrl %}<a href="{{ sessionBaseUrl }}/{{ s.slug | default: s.token }}{{ sessionSuffix }}" class="term-session-link">{% endif %}
      <div class="term-session-entry__row">
        <span class="term-session-entry__idx">[{{ forloop.index }}]</span>
        <span class="term-session-entry__title">{{ s.title }}</span>
      </div>
      <div class="term-session-entry__meta">
        <span>{{ s.durationMinutes | formatDuration }}</span>
        <span class="term-sep">&middot;</span>
        <span>{{ s.turns }} turns</span>
        <span class="term-sep">&middot;</span>
        <span>{{ s.locChanged | formatLoc }} loc</span>
        <span class="term-sep">&middot;</span>
        <span>{{ s.recordedAt | formatDateShort }}</span>
      </div>
      {% if sessionBaseUrl %}</a>{% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {%- comment -%} Footer {%- endcomment -%}
  <div class="term-footer">
    {% if sessionBaseUrl %}
    <span class="term-dim">exported from heyi.am</span>
    {% else %}
    <span class="term-dim">built with <a href="https://heyiam.com" target="_blank" rel="noopener noreferrer">heyiam.com</a></span>
    {% endif %}
  </div>

</div>
