<div class="heyiam-session terminal" data-render-version="2" data-template="terminal">

  {%- comment -%} Prompt-style breadcrumb {%- endcomment -%}
  <div class="term-prompt">
    <span class="term-prompt__char">&#10095;</span>
    <span class="term-prompt__path"><a href="/@{{ user.username }}">{{ user.username }}</a>{% if projectSlug %}/<a href="/@{{ user.username }}/p/{{ projectSlug }}">{{ projectSlug }}</a>{% endif %}/{{ session.title }}</span>
  </div>

  {%- comment -%} # Title {%- endcomment -%}
  <h1 class="term-heading"># {{ session.title }}</h1>

  {%- comment -%} Meta as key=value pairs {%- endcomment -%}
  <div class="term-section">
    <div class="term-comment"># meta</div>
    <table class="term-table term-table--meta">
      <tr><td class="term-table__key">date</td><td class="term-table__eq">=</td><td class="term-table__val"><time datetime="{{ session.recordedAt }}">{{ session.recordedAt | formatDate }}</time></td></tr>
      <tr><td class="term-table__key">source</td><td class="term-table__eq">=</td><td class="term-table__val">{{ session.sourceTool }}</td></tr>
      <tr><td class="term-table__key">active</td><td class="term-table__eq">=</td><td class="term-table__val">{{ session.durationMinutes | formatDuration }}</td></tr>
      <tr><td class="term-table__key">turns</td><td class="term-table__eq">=</td><td class="term-table__val">{{ session.turns }}</td></tr>
      <tr><td class="term-table__key">lines_changed</td><td class="term-table__eq">=</td><td class="term-table__val">{{ session.locChanged | localeNumber }}</td></tr>
      <tr><td class="term-table__key">files</td><td class="term-table__eq">=</td><td class="term-table__val">{{ session.filesChanged }}</td></tr>
    </table>
  </div>

  {%- comment -%} Dev take as > quote {%- endcomment -%}
  {% if session.devTake != blank %}
  <div class="term-section">
    <div class="term-comment"># dev take</div>
    <blockquote class="term-blockquote">&gt; {{ session.devTake }}</blockquote>
  </div>
  {% endif %}

  {%- comment -%} Context {%- endcomment -%}
  {% if session.context != blank %}
  <div class="term-section">
    <div class="term-comment"># context</div>
    <p class="term-context">{{ session.context }}</p>
  </div>
  {% endif %}

  {%- comment -%} Skills {%- endcomment -%}
  {% if session.skills.size > 0 %}
  <div class="term-section">
    <div class="term-comment"># skills</div>
    <div class="term-inline-skills">
      {% for skill in session.skills %}
      <span class="term-skill-tag">{{ skill }}</span>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {%- comment -%} Narrative {%- endcomment -%}
  {% if session.narrative != blank %}
  <div class="term-section">
    <div class="term-comment"># narrative</div>
    <blockquote class="term-blockquote">&gt; {{ session.narrative }}</blockquote>
  </div>
  {% endif %}

  {%- comment -%} Beats as numbered command outputs {%- endcomment -%}
  {% if session.beats.size > 0 %}
  <div class="term-section">
    <div class="term-comment"># execution path</div>
    {% for beat in session.beats %}
    <div class="term-beat">
      <div class="term-beat__header">
        <span class="term-beat__num">[{{ beat.stepNumber }}]</span>
        <span class="term-beat__prefix">$</span>
        <strong class="term-beat__title">{{ beat.title }}</strong>
      </div>
      <p class="term-beat__body">{{ beat.body }}</p>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {%- comment -%} Highlights {%- endcomment -%}
  {% if session.highlights.size > 0 %}
  <div class="term-section">
    <div class="term-comment"># highlights</div>
    {% for h in session.highlights %}
    <div class="term-list-item">* {{ h }}</div>
    {% endfor %}
  </div>
  {% endif %}

  {%- comment -%} Tools {%- endcomment -%}
  {% if session.toolBreakdown.size > 0 %}
  <div class="term-section">
    <div class="term-comment"># tools</div>
    <table class="term-table">
      <tr><td class="term-table__header">TOOL</td><td class="term-table__header">COUNT</td></tr>
      {% for t in session.toolBreakdown %}
      <tr><td class="term-table__key">{{ t.tool }}</td><td class="term-table__val">{{ t.count }}</td></tr>
      {% endfor %}
    </table>
  </div>
  {% endif %}

  {%- comment -%} Top files {%- endcomment -%}
  {% if session.topFiles.size > 0 %}
  <div class="term-section">
    <div class="term-comment"># top files</div>
    {% for f in session.topFiles %}
    <div class="term-file-entry">
      <span class="term-file-path">{{ f.path }}</span>
      <span class="term-file-diff"><span class="term-adds">+{{ f.additions }}</span> <span class="term-dels">-{{ f.deletions }}</span></span>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {%- comment -%} Q&A as stdin/stdout {%- endcomment -%}
  {% if session.qaPairs.size > 0 %}
  <div class="term-section">
    <div class="term-comment"># Q&amp;A</div>
    {% for qa in session.qaPairs %}
    <div class="term-qa">
      <div class="term-qa__question"><span class="term-qa__prefix">stdin&gt;</span> {{ qa.question }}</div>
      <div class="term-qa__answer"><span class="term-qa__prefix">stdout&gt;</span> {{ qa.answer }}</div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {%- comment -%} Agent summary {%- endcomment -%}
  {% if session.agentSummary %}
  <div class="term-section">
    <div class="term-comment"># agent summary</div>
    {% if session.agentSummary.agents.size > 0 %}
    <table class="term-table">
      <tr><td class="term-table__header">AGENT</td><td class="term-table__header">ROLE</td></tr>
      {% for agent in session.agentSummary.agents %}
      <tr><td class="term-table__key">{{ agent.name }}</td><td class="term-table__val">{{ agent.role }}</td></tr>
      {% endfor %}
    </table>
    {% endif %}
    {% if session.agentSummary.summary != blank %}
    <p class="term-context">{{ session.agentSummary.summary }}</p>
    {% endif %}
  </div>
  {% endif %}

</div>
