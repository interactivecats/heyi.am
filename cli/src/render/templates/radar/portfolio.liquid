<div class="heyiam-portfolio radar" data-render-version="2" data-template="radar" data-username="{{ user.username }}">

  <h1 class="project-title">{{ user.displayName }}</h1>
  {% if user.bio != blank %}
  <p class="narrative-text">{{ user.bio }}</p>
  {% endif %}

  {%- comment -%} Stats with SVG arc leverage {%- endcomment -%}
  <div class="stat-grid" role="list" aria-label="Portfolio statistics">
    {% if efficiencyMultiplier %}
    <div class="radar-leverage-arc" role="listitem" aria-label="Leverage multiplier: {{ efficiencyMultiplier }}">
      <svg class="radar-leverage-arc__svg" viewBox="0 0 48 48" width="48" height="48" aria-hidden="true">
        <circle cx="24" cy="24" r="20" fill="none" stroke="currentColor" stroke-width="2" opacity="0.15"/>
        <path d="M 24 4 A 20 20 0 1 1 4 24" fill="none" stroke="var(--accent, #22d3ee)" stroke-width="3" stroke-linecap="round"/>
      </svg>
      <div class="radar-leverage-arc__text">
        <span class="radar-leverage-arc__multiplier" style="color: var(--accent, #22d3ee);">{{ efficiencyMultiplier }}</span>
        <span class="radar-leverage-arc__detail"><span style="opacity: 0.5;">{{ totalDurationMinutes | formatDuration }} you</span> / <span style="color: var(--accent, #22d3ee);">{{ totalAgentDurationMinutes | formatDuration }} agents</span></span>
      </div>
    </div>
    {% endif %}
    <div class="stat-card" role="listitem">
      <div class="stat-card__label">Projects</div>
      <div class="stat-card__value">{{ projects.size }}</div>
    </div>
    <div class="stat-card" role="listitem">
      <div class="stat-card__label">Sessions</div>
      <div class="stat-card__value">{{ totalSessions }}</div>
    </div>
    <div class="stat-card" role="listitem">
      <div class="stat-card__label">Lines</div>
      <div class="stat-card__value">{{ totalLoc | formatLoc }}</div>
    </div>
  </div>

  {% if projects.size > 0 %}
  <div class="card">
    <div class="section-header">
      <h3 class="section-header__title">Projects</h3>
    </div>
    <div class="session-grid">
      {% for project in projects %}
      <div class="session-card">
        <h4 class="session-card__title">{{ project.title }}</h4>
        <span class="session-card__meta">{{ project.totalSessions }} sessions &middot; {{ project.totalLoc | formatLoc }} lines</span>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {% render 'partials/_footer', sessionBaseUrl: sessionBaseUrl %}

</div>
