<div class="heyiam-session minimal" data-render-version="2" data-template="minimal">

  <div class="mn-session">

    {%- comment -%} Breadcrumb as light text (no nav element) {%- endcomment -%}
    <div class="mn-breadcrumb">
      <a href="/@{{ user.username }}">{{ user.username }}</a>
      {% if projectSlug %}
      <span class="mn-breadcrumb-sep">/</span>
      <a href="/@{{ user.username }}/p/{{ projectSlug }}">{{ projectSlug }}</a>
      {% endif %}
      <span class="mn-breadcrumb-sep">/</span>
      <span>{{ session.title }}</span>
    </div>

    {%- comment -%} Title {%- endcomment -%}
    <h1 class="mn-heading">{{ session.title }}</h1>

    {%- comment -%} Meta as inline text {%- endcomment -%}
    <div class="mn-stats">
      <time datetime="{{ session.recordedAt }}">{{ session.recordedAt | formatDate }}</time>
      <span>{{ session.sourceTool }}</span>
      <span>{{ session.durationMinutes | formatDuration }} active</span>
      <span>{{ session.turns }} turns</span>
      <span>{{ session.locChanged | localeNumber }} lines</span>
      <span>{{ session.filesChanged }} files</span>
    </div>

    <hr class="mn-rule" />

    {%- comment -%} Dev take as blockquote {%- endcomment -%}
    {% if session.devTake != blank %}
    <blockquote class="mn-blockquote">
      <p>{{ session.devTake }}</p>
    </blockquote>
    {% endif %}

    {%- comment -%} Context {%- endcomment -%}
    {% if session.context != blank %}
    <p class="mn-context">{{ session.context }}</p>
    {% endif %}

    {%- comment -%} Narrative {%- endcomment -%}
    {% if session.narrative != blank %}
    <div class="mn-section">
      <h2 class="mn-section-heading">Narrative</h2>
      <p class="mn-narrative-text">{{ session.narrative }}</p>
    </div>
    <hr class="mn-rule" />
    {% endif %}

    {%- comment -%} Highlights {%- endcomment -%}
    {% if session.highlights.size > 0 %}
    <div class="mn-section">
      <h2 class="mn-section-heading">Highlights</h2>
      <ul class="mn-list">
        {% for h in session.highlights %}
        <li>{{ h }}</li>
        {% endfor %}
      </ul>
    </div>
    <hr class="mn-rule" />
    {% endif %}

    {%- comment -%} Beats as numbered list {%- endcomment -%}
    {% if session.beats.size > 0 %}
    <div class="mn-section">
      <h2 class="mn-section-heading">Execution Path</h2>
      <ol class="mn-beats-list beats-list">
        {% for beat in session.beats %}
        <li class="mn-beat-item">
          <strong>{{ beat.title }}</strong>
          <p>{{ beat.body }}</p>
        </li>
        {% endfor %}
      </ol>
    </div>
    <hr class="mn-rule" />
    {% endif %}

    {%- comment -%} Q&A as simple pairs {%- endcomment -%}
    {% if session.qaPairs.size > 0 %}
    <div class="mn-section">
      <h2 class="mn-section-heading">Q&amp;A</h2>
      <div class="mn-qa-list">
        {% for qa in session.qaPairs %}
        <div class="mn-qa-pair qa-pair">
          <p class="mn-qa-question">{{ qa.question }}</p>
          <p class="mn-qa-answer">{{ qa.answer }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
    <hr class="mn-rule" />
    {% endif %}

    {%- comment -%} Tools {%- endcomment -%}
    {% if session.toolBreakdown.size > 0 %}
    <div class="mn-section">
      <h2 class="mn-section-heading">Tools</h2>
      <div class="mn-inline-list">
        {% for t in session.toolBreakdown %}
        <span class="mn-inline-item">{{ t.tool }} ({{ t.count }})</span>
        {% endfor %}
      </div>
    </div>
    <hr class="mn-rule" />
    {% endif %}

    {%- comment -%} Top files {%- endcomment -%}
    {% if session.topFiles.size > 0 %}
    <div class="mn-section">
      <h2 class="mn-section-heading">Top Files</h2>
      <ul class="mn-file-list">
        {% for f in session.topFiles %}
        <li class="mn-file-item">
          <span class="mn-file-path">{{ f.path }}</span>
          <span class="mn-file-diff">+{{ f.additions }} -{{ f.deletions }}</span>
        </li>
        {% endfor %}
      </ul>
    </div>
    <hr class="mn-rule" />
    {% endif %}

    {%- comment -%} Skills {%- endcomment -%}
    {% if session.skills.size > 0 %}
    <div class="mn-section">
      <h2 class="mn-section-heading">Skills</h2>
      <div class="mn-tag-list">
        {% for skill in session.skills %}
        <span class="mn-tag">{{ skill }}</span>
        {% endfor %}
      </div>
    </div>
    {% endif %}

  </div>

</div>
