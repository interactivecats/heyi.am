<div class="heyiam-project mono" data-render-version="2" data-template="mono"{% if sessionBaseUrl %} data-session-base-url="{{ sessionBaseUrl }}"{% endif %} data-username="{{ user.username }}" data-project-slug="{{ project.slug }}">

  {%- comment -%} Terminal prompt {%- endcomment -%}
  <div class="term-prompt">
    <span class="term-prompt__char">&#10095;</span> <span class="term-prompt__path">@{{ user.username }}/{{ project.slug }}</span>
  </div>

  <h1 class="term-heading" data-editable="title"># {{ project.title }}</h1>

  {% render 'partials/_links', project: project %}

  {% render 'partials/_screenshot', project: project %}

  {%- comment -%} Stats as terminal table with compact leverage {%- endcomment -%}
  <div class="term-section">
    <div class="term-comment"># stats</div>
    <table class="term-table">
      {% if efficiencyMultiplier %}
      <tr>
        <td class="term-table__key">Leverage</td>
        <td class="term-table__val"><span style="color: var(--accent, #4ade80); font-weight: 700;">{{ efficiencyMultiplier }}</span> <span style="opacity: 0.5;">{{ project.totalDurationMinutes | formatDuration }} you</span> <span style="color: var(--accent, #4ade80);">{{ project.totalAgentDurationMinutes | formatDuration }} agents</span></td>
      </tr>
      {% else %}
      <tr><td class="term-table__key">Time</td><td class="term-table__val">{{ project.totalDurationMinutes | formatDuration }}</td></tr>
      {% endif %}
      <tr><td class="term-table__key">Sessions</td><td class="term-table__val">{{ project.totalSessions }}</td></tr>
      <tr><td class="term-table__key">Lines changed</td><td class="term-table__val">{{ project.totalLoc | formatLoc }}</td></tr>
      <tr><td class="term-table__key">Files</td><td class="term-table__val">{{ project.totalFilesChanged }}</td></tr>
      {% if project.totalTokens %}<tr><td class="term-table__key">Tokens</td><td class="term-table__val">{{ project.totalTokens | formatTokens }}</td></tr>{% endif %}
    </table>
  </div>

  {%- comment -%} Narrative {%- endcomment -%}
  {% if project.narrative != blank %}
  <div class="term-section">
    <div class="term-comment"># narrative</div>
    <blockquote class="term-blockquote">{{ project.narrative }}</blockquote>
  </div>
  {% endif %}

  {% render 'partials/_work-timeline', sessionsJson: sessionsJson %}
  {% render 'partials/_growth-chart', project: project, growthJson: growthJson %}

  {%- comment -%} Key decisions {%- endcomment -%}
  {% if arc.size > 0 %}
  <div class="term-section">
    <div class="term-comment"># key decisions</div>
    {% for phase in arc limit: 3 %}
    <div class="term-decision">
      <span class="term-decision__bullet">*</span>
      <strong>{{ phase.title }}</strong> &mdash; {{ phase.description }}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% render 'partials/_source-breakdown', sourceCounts: sourceCounts %}

  {% if arc.size > 0 %}
  <div class="term-section">
    <div class="term-comment"># phases</div>
    <div class="term-tree">
      {% for phase in arc %}
      <div class="term-tree__node">
        {% if forloop.last %}<span class="term-tree__branch">&#9492;&#9472;&#9472;</span>{% else %}<span class="term-tree__branch">&#9500;&#9472;&#9472;</span>{% endif %}
        <span class="term-tree__label">{{ phase.title }}</span>
        <span class="term-tree__desc">&mdash; {{ phase.description }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {% render 'partials/_skills', skills: project.skills %}

  {% if featuredSessions.size > 0 %}
  <div class="term-section">
    <div class="term-comment"># sessions ({{ sessions.size }} total)</div>
    {% for session in featuredSessions %}
    <div class="term-session-entry">
      {% if sessionBaseUrl %}<a href="{{ sessionBaseUrl }}/{{ session.slug | default: session.token }}.html" class="term-session-link">{% endif %}
      <span class="term-session-entry__idx">[{{ forloop.index }}]</span>
      <span class="term-session-entry__title">{{ session.title }}</span>
      <span class="term-session-entry__meta">{{ session.durationMinutes | formatDuration }} &middot; {{ session.turns }} turns &middot; {{ session.locChanged | formatLoc }} loc</span>
      {% if sessionBaseUrl %}</a>{% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% render 'partials/_footer', sessionBaseUrl: sessionBaseUrl %}

</div>
