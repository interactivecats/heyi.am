<div class="heyiam-project kinetic" data-render-version="2" data-template="kinetic"{% if sessionBaseUrl %} data-session-base-url="{{ sessionBaseUrl }}"{% endif %} data-username="{{ user.username }}" data-project-slug="{{ project.slug }}">

  {%- comment -%} Hero row: title + stats side by side {%- endcomment -%}
  <div class="kinetic-hero">
    <div class="kinetic-hero__title-block">
      <h1 class="project-title" data-editable="title">{{ project.title }}</h1>
      {% render 'partials/_links', project: project %}
    </div>
    <div class="kinetic-hero__stats">
      {%- comment -%} Simplified leverage: multiplier large, detail small, no legend {%- endcomment -%}
      {% if efficiencyMultiplier %}
      <div class="kinetic-leverage" role="status" aria-label="Leverage: {{ efficiencyMultiplier }}">
        <div class="kinetic-leverage__multiplier" style="color: var(--accent, #f97316);">{{ efficiencyMultiplier }}</div>
        <div class="kinetic-leverage__detail">
          <span style="opacity: 0.5;">{{ project.totalDurationMinutes | formatDuration }} you</span>
          <span style="opacity: 0.35;" aria-hidden="true">/</span>
          <span style="color: var(--accent, #f97316);">{{ project.totalAgentDurationMinutes | formatDuration }} agents</span>
        </div>
        <div class="kinetic-leverage__bar" aria-hidden="true">
          <div class="kinetic-leverage__bar-fill" style="background: var(--accent, #f97316);"></div>
        </div>
      </div>
      {% endif %}
      <div class="stat-grid--compact">
        {% unless efficiencyMultiplier %}
        <div class="stat-card">
          <div class="stat-card__label">Time</div>
          <div class="stat-card__value">{{ project.totalDurationMinutes | formatDuration }}</div>
        </div>
        {% endunless %}
        <div class="stat-card">
          <div class="stat-card__label">Sessions</div>
          <div class="stat-card__value">{{ project.totalSessions }}</div>
        </div>
        <div class="stat-card">
          <div class="stat-card__label">Lines changed</div>
          <div class="stat-card__value">{{ project.totalLoc | formatLoc }}</div>
        </div>
        <div class="stat-card">
          <div class="stat-card__label">Files</div>
          <div class="stat-card__value">{{ project.totalFilesChanged }}</div>
        </div>
        {% if project.totalTokens %}
        <div class="stat-card">
          <div class="stat-card__label">Tokens</div>
          <div class="stat-card__value">{{ project.totalTokens | formatTokens }}</div>
        </div>
        {% endif %}
      </div>
    </div>
  </div>

  {%- comment -%} Screenshot {%- endcomment -%}
  {% render 'partials/_screenshot', project: project %}

  {%- comment -%} Full-width narrative {%- endcomment -%}
  <div class="kinetic-narrative">
    {% render 'partials/_narrative', narrative: project.narrative %}
  </div>

  {%- comment -%} Charts {%- endcomment -%}
  <div class="kinetic-charts">
    {% render 'partials/_work-timeline', sessionsJson: sessionsJson %}
    {% render 'partials/_growth-chart', project: project, growthJson: growthJson %}
  </div>

  {%- comment -%} Two-col: phases + sources {%- endcomment -%}
  <div class="two-col">
    {% render 'partials/_phases', arc: arc %}
    {% render 'partials/_source-breakdown', sourceCounts: sourceCounts %}
  </div>

  {%- comment -%} Skills {%- endcomment -%}
  {% render 'partials/_skills', skills: project.skills %}

  {%- comment -%} Sessions {%- endcomment -%}
  {% render 'partials/_session-cards', featuredSessions: featuredSessions, sessionBaseUrl: sessionBaseUrl, totalSessionCount: sessions.size %}

  {% render 'partials/_footer', sessionBaseUrl: sessionBaseUrl %}

</div>
