<%!--
  TIMELINE layout: Vertical timeline with dates, emphasizing
  chronological progression and growth.
--%>
<div class="section-label">
  <span>Timeline</span>
  <span>{length(@entries)} sessions</span>
</div>

<div style="position:relative;padding-left:40px;">
  <%!-- Vertical line --%>
  <div style="position:absolute;left:15px;top:0;bottom:0;width:1px;background:var(--faint);">
  </div>

  <%= for {entry, idx} <- Enum.with_index(@entries) do %>
    <% share = entry.share %>
    <a
      href={"/s/#{share.token}"}
      style="display:block;position:relative;padding:24px 0 40px;text-decoration:none;color:inherit;"
    >
      <%!-- Timeline dot --%>
      <div style={"position:absolute;left:-33px;top:28px;width:12px;height:12px;border-radius:50%;background:var(--#{@accent});border:3px solid var(--bg);z-index:1;"}>
      </div>

      <%!-- Date label --%>
      <%= if share.session_month do %>
        <div style={"font-family:var(--hmono);font-size:11px;font-weight:500;color:var(--#{@accent});margin-bottom:8px;text-transform:uppercase;letter-spacing:0.04em;"}>
          {share.session_month}
        </div>
      <% end %>

      <h2 style="font-size:22px;font-weight:600;line-height:1.25;letter-spacing:-0.02em;margin-bottom:8px;">
        {share.title}
      </h2>

      <%= if share.context do %>
        <p style="font-size:14px;color:var(--gray);line-height:1.5;margin-bottom:10px;">
          {share.context}
        </p>
      <% end %>
      <%= if share.one_line_summary && !share.context do %>
        <p style="font-size:14px;color:var(--gray);line-height:1.5;margin-bottom:10px;">
          {share.one_line_summary}
        </p>
      <% end %>

      <div style="font-family:var(--hmono);font-size:12px;color:var(--light);display:flex;gap:16px;margin-bottom:10px;">
        <%= if share.step_count do %>
          <span>{share.step_count} steps</span>
        <% end %>
        <%= if share.duration_minutes do %>
          <span>{share.duration_minutes} min</span>
        <% end %>
        <span>{share.source_tool || "Claude Code"}</span>
      </div>

      <%= if share.developer_take do %>
        <p style="font-size:14px;font-style:italic;color:var(--gray);line-height:1.6;margin-top:8px;">
          "{share.developer_take}"
        </p>
      <% end %>

      <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:10px;">
        <%= for skill <- (share.skills || []) do %>
          <span style="font-size:11px;font-family:var(--hmono);padding:3px 10px;border-radius:4px;background:var(--faint);color:var(--violet);">
            {skill}
          </span>
        <% end %>
      </div>
    </a>
  <% end %>
</div>
