<div class="page-wrap" style="max-width:1200px;">
  <%!-- Top Nav --%>
  <div class="top-nav">
    <a href="/" class="logo">heyi<b>.</b>am</a>
    <div class="nav-links">
      <%= if @current_scope && @current_scope.user do %>
        <% user = @current_scope.user %>
        <a href={"/" <> (user.username || "")}>Portfolio</a>
        <a href={"/" <> (user.username || "") <> "/edit"}>Edit</a>
        <span style="font-family:var(--font-mono);font-size:12px;color:var(--gray);">@{user.username || user.email}</span>
      <% else %>
        <a href="/users/register" class="btn-primary" style="padding:8px 20px;font-size:13px;">Get Started</a>
      <% end %>
    </div>
  </div>

  <%!-- Hero --%>
  <section class="landing-hero" style="display:grid;grid-template-columns:1.2fr 0.8fr;gap:48px;align-items:center;">
    <div>
      <h1>
        The End of AI Fluff.<br/>
        <span>The Start of Provable Thinking.</span>
      </h1>
      <p>
        Turn your AI coding sessions into evidence-backed developer portfolios. We capture the friction, the pivots, and the prompts that prove you are more than a script executor.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:12px;">
        <a href="/users/register" class="btn-primary" style="padding:14px 28px;font-size:15px;">
          Publish your first session
          <span style="font-size:18px;">&rarr;</span>
        </a>
        <a href="/s/demo" class="btn-secondary" style="padding:14px 28px;font-size:15px;">
          View Live Demo
        </a>
      </div>
    </div>

    <%!-- Terminal visual --%>
    <div class="terminal-panel" style="font-size:13px;line-height:1.8;">
      <div class="terminal-panel__header">
        <span style="font-size:10px;text-transform:uppercase;letter-spacing:0.1em;font-weight:600;color:rgba(255,255,255,0.4);">Workbench Stream</span>
        <div class="terminal-panel__dots">
          <div class="terminal-panel__dot" style="background:#f9507a;"></div>
          <div class="terminal-panel__dot" style="background:#f59e0b;"></div>
          <div class="terminal-panel__dot" style="background:#06b6a0;"></div>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:8px;">
        <div style="display:flex;gap:12px;">
          <span style="color:rgba(255,255,255,0.3);flex-shrink:0;">10:42:01</span>
          <span style="color:var(--brand);font-weight:600;">PROMPT_IN</span>
          <span>"Refactor the billing microservice to support tiered pricing..."</span>
        </div>
        <div style="display:flex;gap:12px;">
          <span style="color:rgba(255,255,255,0.3);flex-shrink:0;">10:42:05</span>
          <span style="color:rgba(255,255,255,0.5);font-weight:600;">ANALYSIS</span>
          <span style="color:rgba(255,255,255,0.5);">Scanning schema... Detected N+1 query vulnerability.</span>
        </div>
        <div style="display:flex;gap:12px;padding:8px 0;border-top:1px solid rgba(255,255,255,0.08);border-bottom:1px solid rgba(255,255,255,0.08);">
          <span style="color:rgba(255,255,255,0.3);flex-shrink:0;">10:42:10</span>
          <span style="color:var(--brand);font-weight:600;">USER_PIVOT</span>
          <span>"Wait, don't use the ORM. Write raw SQL."</span>
        </div>
        <div style="display:flex;gap:12px;">
          <span style="color:rgba(255,255,255,0.3);flex-shrink:0;">10:42:15</span>
          <span style="color:#06b6a0;font-weight:600;">LOG_CAPTURED</span>
          <span style="color:rgba(255,255,255,0.5);font-style:italic;">Proof of nuance captured. Adding to portfolio...</span>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <%!-- Value Prop: Process = Proof --%>
  <section class="landing-section">
    <h2>Your Process is Your Proof</h2>
    <div class="section-sub">Technical Validation Pipeline</div>

    <div class="feature-grid">
      <div class="feature-card">
        <div class="feature-card__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="2"><polyline points="4,17 10,11 4,5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
        </div>
        <h3>CLI Ingestion</h3>
        <p>We don't just snapshot code. We ingest raw shell history, IDE events, and LLM conversations into a single verified stream.</p>
        <div class="terminal-block" style="margin-top:16px;padding:10px 16px;font-size:12px;">
          <span class="prompt">$</span> ccs publish
        </div>
      </div>

      <div class="feature-card">
        <div class="feature-card__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h3>AI Enhancement</h3>
        <p>Our models highlight where you disagreed with the AI, where you corrected hallucinations, and where your logic led the way.</p>
        <div style="margin-top:16px;display:flex;flex-direction:column;gap:6px;">
          <div style="display:flex;align-items:center;gap:8px;">
            <span style="color:var(--brand);font-size:16px;">&#10003;</span>
            <span style="font-family:var(--font-mono);font-size:11px;color:var(--gray);text-transform:uppercase;">Intent Extraction</span>
          </div>
          <div style="display:flex;align-items:center;gap:8px;">
            <span style="color:var(--brand);font-size:16px;">&#10003;</span>
            <span style="font-family:var(--font-mono);font-size:11px;color:var(--gray);text-transform:uppercase;">Pivot Detection</span>
          </div>
        </div>
      </div>

      <div class="feature-card">
        <div class="feature-card__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h3>Cryptographic Sealing</h3>
        <p>Every portfolio entry is cryptographically hashed. Recruiters don't have to take your word — they can verify the session signature.</p>
        <div style="margin-top:16px;font-family:var(--font-mono);font-size:10px;color:var(--gray);background:var(--surface-low);padding:12px;border-radius:var(--radius-sm);word-break:break-all;">
          HASH_256: e3b0c44298fc1c149afbf4c8996fb924...
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <%!-- Featured Takes --%>
  <section class="landing-section">
    <div style="display:flex;justify-content:space-between;align-items:end;margin-bottom:48px;">
      <div>
        <h2 style="margin-bottom:4px;">Featured Takes</h2>
        <p style="font-family:var(--font-body);font-size:15px;color:var(--gray);">Engineers building the future, one provable pivot at a time.</p>
      </div>
      <a href="#" style="font-family:var(--font-mono);font-size:12px;text-transform:uppercase;letter-spacing:0.1em;color:var(--brand);font-weight:600;text-decoration:none;">View Directory &rarr;</a>
    </div>

    <div class="takes-grid">
      <div class="take-card">
        <div class="take-card__hero" style="background:var(--surface-high);">
          <span class="take-card__hero-text">BEN.js</span>
        </div>
        <div class="take-card__info">
          <span class="take-card__name">Ben &mdash; Brutalist</span>
          <span class="take-card__role">L5 Eng</span>
        </div>
        <div class="take-card__quote">
          "The AI suggested a recursive fix. I pivoted to an iterative stack to avoid the overflow risk."
        </div>
        <div style="margin-top:12px;">
          <div style="display:flex;justify-content:space-between;font-family:var(--font-mono);font-size:10px;margin-bottom:4px;">
            <span style="color:var(--light);text-transform:uppercase;letter-spacing:0.08em;">AI Collaboration</span>
            <span style="color:var(--gray);">92%</span>
          </div>
          <div style="height:4px;background:var(--faint);border-radius:2px;overflow:hidden;">
            <div style="height:100%;width:92%;background:var(--brand);border-radius:2px;"></div>
          </div>
        </div>
      </div>

      <div class="take-card">
        <div class="take-card__hero" style="background:var(--surface-low);">
          <span class="take-card__hero-text" style="font-family:var(--font-display);letter-spacing:-0.03em;">SARAH.LOG</span>
        </div>
        <div class="take-card__info">
          <span class="take-card__name">Sarah &mdash; Editorial</span>
          <span class="take-card__role">Founder</span>
        </div>
        <div class="take-card__quote">
          "Documenting how we built our vector search layer. Every hallucination correction is annotated."
        </div>
        <div style="margin-top:12px;">
          <div style="display:flex;justify-content:space-between;font-family:var(--font-mono);font-size:10px;margin-bottom:4px;">
            <span style="color:var(--light);text-transform:uppercase;letter-spacing:0.08em;">AI Collaboration</span>
            <span style="color:var(--gray);">87%</span>
          </div>
          <div style="height:4px;background:var(--faint);border-radius:2px;overflow:hidden;">
            <div style="height:100%;width:87%;background:var(--brand);border-radius:2px;"></div>
          </div>
        </div>
      </div>

      <div class="take-card">
        <div class="take-card__hero" style="background:var(--ink);">
          <span style="font-family:var(--font-mono);font-size:11px;color:#4ade80;padding:20px;">
            &gt; Alex.session.init()<br/>
            &gt; status: EXCELLENT<br/>
            &gt; proof_of_work: VERIFIED
          </span>
        </div>
        <div class="take-card__info">
          <span class="take-card__name">Alex &mdash; Terminal</span>
          <span class="take-card__role">Staff SRE</span>
        </div>
        <div class="take-card__quote">
          "Post-mortem coding. Proving how I salvaged a live production outage while the AI kept suggesting 'reboot'."
        </div>
        <div style="margin-top:12px;">
          <div style="display:flex;justify-content:space-between;font-family:var(--font-mono);font-size:10px;margin-bottom:4px;">
            <span style="color:var(--light);text-transform:uppercase;letter-spacing:0.08em;">AI Collaboration</span>
            <span style="color:var(--gray);">95%</span>
          </div>
          <div style="height:4px;background:var(--faint);border-radius:2px;overflow:hidden;">
            <div style="height:100%;width:95%;background:var(--brand);border-radius:2px;"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%!-- Dual Audience (Dark Section) --%>
  <section class="dual-audience" style="margin:0 -48px;padding:80px 48px;">
    <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;">
      <div>
        <div class="col-label" style="color:var(--brand);">For Developers</div>
        <h2>Prove your thinking.</h2>
        <p>
          The world doesn't need more "prompt engineers." It needs engineers who lead the prompts. Show your internal reasoning, your architecture pivots, and your mastery over the tools.
        </p>
        <div style="display:flex;flex-direction:column;gap:12px;">
          <div style="display:flex;gap:12px;align-items:center;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="2"><path d="M9 12l2 2 4-4"/><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/></svg>
            <span style="font-family:var(--font-mono);font-size:13px;color:rgba(255,255,255,0.7);">Verified Session Hash attached to every commit.</span>
          </div>
          <div style="display:flex;gap:12px;align-items:center;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="2"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>
            <span style="font-family:var(--font-mono);font-size:13px;color:rgba(255,255,255,0.7);">Personal "Reasoning Index" to showcase seniority.</span>
          </div>
        </div>
      </div>

      <div style="border-left:1px solid rgba(255,255,255,0.1);padding-left:80px;">
        <div class="col-label" style="color:var(--violet);">For Managers</div>
        <h2>Hire with signal.</h2>
        <p>
          Stop reviewing generic take-home tests that could be GPT-4 hallucinations. Review the actual problem-solving process. See how they handle complexity, errors, and scale.
        </p>
        <div style="background:rgba(255,255,255,0.05);padding:20px;border-radius:var(--radius-md);border:1px solid rgba(255,255,255,0.08);">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--violet)" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            <span style="font-family:var(--font-mono);font-size:11px;text-transform:uppercase;letter-spacing:0.1em;font-weight:600;color:rgba(255,255,255,0.5);">Signal Score Matrix</span>
          </div>
          <div style="display:flex;flex-direction:column;gap:0;">
            <div style="display:flex;justify-content:space-between;font-family:var(--font-mono);font-size:12px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.08);">
              <span style="color:rgba(255,255,255,0.5);">Structural Logic</span>
              <span style="color:rgba(255,255,255,0.8);">98th Percentile</span>
            </div>
            <div style="display:flex;justify-content:space-between;font-family:var(--font-mono);font-size:12px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.08);">
              <span style="color:rgba(255,255,255,0.5);">Prompt Precision</span>
              <span style="color:rgba(255,255,255,0.8);">High Efficiency</span>
            </div>
            <div style="display:flex;justify-content:space-between;font-family:var(--font-mono);font-size:12px;padding:8px 0;">
              <span style="color:rgba(255,255,255,0.5);">Friction Resolution</span>
              <span style="color:rgba(255,255,255,0.8);">Immediate</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%!-- Final CTA --%>
  <section class="cta-section">
    <h2>Ready to stop being an "Operator" and start being an Author?</h2>
    <p>Join the waitlist for the heyi Terminal Beta. Start building your provable thinking today.</p>
    <div class="email-capture">
      <input type="email" placeholder="developer@studio.heyi" />
      <a href="/users/register" class="btn-primary" style="padding:12px 28px;">Secure Early Access</a>
    </div>
    <div style="margin-top:24px;font-family:var(--font-mono);font-size:10px;color:var(--light);text-transform:uppercase;letter-spacing:0.1em;">
      Available for VS Code, JetBrains, and Terminal via CLI
    </div>
  </section>

  <%!-- Footer --%>
  <footer style="padding:48px 0 32px;border-top:1px solid var(--ghost-border);display:grid;grid-template-columns:2fr 1fr 1fr;gap:24px;">
    <div>
      <a href="/" class="logo" style="display:block;margin-bottom:12px;">heyi<b>.</b>am</a>
      <p style="font-family:var(--font-mono);font-size:11px;color:var(--light);max-width:280px;line-height:1.6;">
        &copy; 2024 heyi.am Engineering. Built for the era of high-density thinking.
      </p>
    </div>
    <div>
      <div style="font-family:var(--font-mono);font-size:11px;color:var(--brand);font-weight:600;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:12px;">Resources</div>
      <div style="display:flex;flex-direction:column;gap:6px;">
        <a href="#" style="font-family:var(--font-mono);font-size:11px;color:var(--gray);text-decoration:none;">System Status</a>
        <a href="#" style="font-family:var(--font-mono);font-size:11px;color:var(--gray);text-decoration:none;">API Docs</a>
        <a href="#" style="font-family:var(--font-mono);font-size:11px;color:var(--gray);text-decoration:none;">Changelog</a>
      </div>
    </div>
    <div>
      <div style="font-family:var(--font-mono);font-size:11px;color:var(--brand);font-weight:600;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:12px;">Network</div>
      <div style="display:flex;flex-direction:column;gap:6px;">
        <a href="#" style="font-family:var(--font-mono);font-size:11px;color:var(--gray);text-decoration:none;">GitHub</a>
        <a href="#" style="font-family:var(--font-mono);font-size:11px;color:var(--gray);text-decoration:none;">Security</a>
        <a href="#" style="font-family:var(--font-mono);font-size:11px;color:var(--gray);text-decoration:none;">Privacy</a>
      </div>
    </div>
  </footer>
</div>

<style>
  @media (max-width: 768px) {
    .landing-hero { grid-template-columns: 1fr !important; }
    .landing-hero > div:last-child { display: none; }
    .dual-audience > div { grid-template-columns: 1fr !important; gap: 48px !important; }
    .dual-audience > div > div:last-child { border-left: none !important; padding-left: 0 !important; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 48px; }
    footer { grid-template-columns: 1fr !important; }
  }
</style>
