{
  "name": "claude-code-summary",
  "version": "0.1.0",
  "description": "Summarize and analyze Claude Code sessions",
  "type": "module",
  "bin": {
    "ccs": "./dist/index.js",
    "claude-code-summary": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && cd app && npm run build",
    "dev": "npx concurrently \"npm:dev:api\" \"npm:dev:frontend\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:app": "cd app && npm run dev",
    "dev:frontend": "cd app && npm run dev",
    "capture": "tsx src/capture.ts",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@resvg/resvg-js": "^2.6.2",
    "commander": "^13.1.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "open": "^10.1.0",
    "satori": "^0.25.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
