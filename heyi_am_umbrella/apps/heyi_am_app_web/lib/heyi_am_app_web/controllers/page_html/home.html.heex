  </div>
</section>

<%!-- ═══ CTA ═══ --%>
<section class="lk-final-cta">
  <div class="lk-hero-bg-text">ship it</div>
  <h2>Your sessions already<br>prove the work.</h2>
  <p>heyi.am turns that proof into a portfolio worth sending.</p>
  <div class="lk-final-cmd" id="copy-cmd-2">
    <span class="lk-tm-prompt">$</span> npx heyiam
  </div>
  <br>
  <div class="lk-hero-ctas" style="justify-content: center;">
    <a href={~p"/users/register"} class="lk-btn-fill">Get started free</a>
    <a href={HeyiAmAppWeb.Helpers.public_url("/ben")} class="lk-btn-ghost">View example →</a>
  </div>
</section>

<footer class="lk-footer">
  <span>© 2026 heyi.am</span>
  <div style="display: flex; gap: 1.5rem;">
    <a href={~p"/terms"}>Terms</a>
    <a href={~p"/privacy"}>Privacy</a>
    <a href="https://github.com/interactivecats/heyi.am" target="_blank" rel="noopener noreferrer">GitHub</a>
  </div>
</footer>

</div>

<script>
  // Copy commands
  document.querySelectorAll('[id^="copy-cmd"]').forEach(el => {
    el.addEventListener('click', () => {
      navigator.clipboard.writeText('npx heyiam');
      const hint = el.querySelector('.lk-hero-cmd-hint');
      if (hint) hint.textContent = 'Copied!';
    });
  });
</script>
