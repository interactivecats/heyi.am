<div class="lk">

<%!-- ═══ Nav ═══ --%>
<nav class="lk-nav">
  <a href="/" class="lk-nav-logo">heyi<span>.</span>am</a>
  <div class="lk-nav-links">
    <a href="#how">How it works</a>
    <a href={HeyiAmAppWeb.Helpers.public_url("/ben")}>Example</a>
    <a href="https://github.com/interactivecats/heyi.am" target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href={~p"/users/log-in"} class="lk-nav-link-auth">Log in</a>
    <a href={~p"/users/register"} class="lk-nav-btn">Sign up</a>
  </div>
</nav>

<%!-- ═══ Hero ═══ --%>
<section class="lk-hero">
  <div class="lk-hero-bg-text">heyi.am</div>
  <div class="lk-hero-content">
    <div class="lk-hero-eyebrow">FOR AI-NATIVE DEVELOPERS</div>
    <h1>
      Show your<br>
      <span class="lk-text-cycle">
        <span class="lk-text-cycle-spacer">judgment.</span>
        <span class="lk-text-cycle-word">decisions.</span>
        <span class="lk-text-cycle-word">thinking.</span>
        <span class="lk-text-cycle-word">execution.</span>
        <span class="lk-text-cycle-word">judgment.</span>
      </span>
    </h1>

    <div class="lk-hero-body">
      <p class="lk-hero-desc">
        Turn your Claude Code, Cursor, and Gemini sessions into project case studies. Real timelines. Real decisions. Real stats.
      </p>
      <div class="lk-terminal-mini">
        <div><span class="lk-tm-prompt">$</span> npx heyiam</div>
        <div><span class="lk-tm-dim"># scanning 21 sessions...</span></div>
        <div><span class="lk-tm-ok">✓</span> 3 projects · 8 case studies</div>
        <div><span class="lk-tm-ok">✓</span> Published → heyi.am/ben</div>
      </div>
    </div>

    <div class="lk-hero-cmd-row">
      <div class="lk-hero-cmd" id="copy-cmd">
        <span class="lk-tm-prompt">$</span> npx heyiam
        <span class="lk-hero-cmd-hint" id="copy-hint">Copy</span>
      </div>
      <a href={HeyiAmAppWeb.Helpers.public_url("/ben")} class="lk-btn-ghost">See example portfolio</a>
    </div>
    <p class="lk-hero-no-signup">No signup required · runs locally · free</p>
  </div>
</section>

<%!-- ═══ Marquee ═══ --%>
<div class="lk-strip">
  <div class="lk-strip-track">
    <span class="lk-strip-item"><span class="lk-strip-dot"></span>Claude Code</span>
    <span class="lk-strip-item"><span class="lk-strip-dot"></span>Cursor</span>
    <span class="lk-strip-item"><span class="lk-strip-dot"></span>OpenAI Codex</span>
    <span class="lk-strip-item"><span class="lk-strip-dot"></span>Gemini CLI</span>
    <span class="lk-strip-item"><span class="lk-strip-dot"></span>Project Narratives</span>
    <span class="lk-strip-item"><span class="lk-strip-dot"></span>Build Timelines</span>
    <span class="lk-strip-item"><span class="lk-strip-dot"></span>Case Studies</span>
    <span class="lk-strip-item"><span class="lk-strip-dot"></span>Accurate Stats</span>
    <span class="lk-strip-item"><span class="lk-strip-dot"></span>Claude Code</span>
    <span class="lk-strip-item"><span class="lk-strip-dot"></span>Cursor</span>
    <span class="lk-strip-item"><span class="lk-strip-dot"></span>OpenAI Codex</span>
    <span class="lk-strip-item"><span class="lk-strip-dot"></span>Gemini CLI</span>
    <span class="lk-strip-item"><span class="lk-strip-dot"></span>Project Narratives</span>
    <span class="lk-strip-item"><span class="lk-strip-dot"></span>Build Timelines</span>
    <span class="lk-strip-item"><span class="lk-strip-dot"></span>Case Studies</span>
    <span class="lk-strip-item"><span class="lk-strip-dot"></span>Accurate Stats</span>
  </div>
</div>

<%!-- ═══ The Transformation ═══ --%>
<section id="how" class="lk-section">
  <div class="lk-section-tag">The transformation</div>
  <div class="lk-section-title">From git log to project story.</div>
  <div class="lk-section-desc">Same project. One tells you what changed. The other tells you why.</div>

  <div class="lk-transform-grid">
    <%!-- Left: Git commits --%>
    <div class="lk-transform-left">
      <div class="lk-git-header">
        <span class="lk-git-icon">⌥</span> git log --oneline
      </div>
      <div class="lk-git-log">
        <div class="lk-git-commit"><span class="lk-git-hash">e4a1f09</span> fix: SSE keepalive for idle conns</div>
        <div class="lk-git-commit"><span class="lk-git-hash">bc47d12</span> test: verify 10k concurrent SSE</div>
        <div class="lk-git-commit"><span class="lk-git-hash">a3f8d21</span> fix: memory leak in SSE pool</div>
        <div class="lk-git-commit"><span class="lk-git-hash">c7b2e41</span> fix: SSE reconnection on timeout</div>
        <div class="lk-git-commit"><span class="lk-git-hash">91d3f8a</span> chore: remove dead WS code</div>
        <div class="lk-git-commit"><span class="lk-git-hash">7e1b4c9</span> refactor: WS → SSE pipeline</div>
        <div class="lk-git-commit"><span class="lk-git-hash">f92a3e5</span> revert: undo ORM migration</div>
        <div class="lk-git-commit"><span class="lk-git-hash">2d8c7a1</span> feat: ORM migration for analytics</div>
        <div class="lk-git-commit"><span class="lk-git-hash">83b1e4f</span> fix: race in event aggregator</div>
        <div class="lk-git-commit"><span class="lk-git-hash">4f7c3d2</span> fix: pool exhaustion under load</div>
        <div class="lk-git-commit"><span class="lk-git-hash">b5e91f3</span> fix: WS drops at 10k conns</div>
        <div class="lk-git-commit"><span class="lk-git-hash">d1e9a7c</span> test: WS integration tests</div>
        <div class="lk-git-commit"><span class="lk-git-hash">72f6b3a</span> feat: WS heartbeat + reconnect</div>
        <div class="lk-git-commit"><span class="lk-git-hash">8ca2d67</span> feat: WebSocket pipeline</div>
        <div class="lk-git-commit"><span class="lk-git-hash">e5d2c91</span> feat: event ingestion worker</div>
        <div class="lk-git-commit"><span class="lk-git-hash">3b6f2e8</span> feat: D3 chart rendering</div>
        <div class="lk-git-commit"><span class="lk-git-hash">a92c1d4</span> feat: analytics API endpoints</div>
        <div class="lk-git-commit"><span class="lk-git-hash">19e7f4b</span> feat: time-series queries</div>
        <div class="lk-git-commit"><span class="lk-git-hash">6e8d5b3</span> feat: PG schema for events</div>
        <div class="lk-git-commit"><span class="lk-git-hash">47c9d1e</span> feat: event partitioning</div>
        <div class="lk-git-commit"><span class="lk-git-hash">c4d8a23</span> feat: responsive widget grid</div>
        <div class="lk-git-commit"><span class="lk-git-hash">d39a7c4</span> init: scaffold</div>
      </div>
      <div class="lk-git-footer">
        21 commits. No context. No decisions. No story.
      </div>
    </div>

    <%!-- Right: heyi.am project page --%>
    <div class="lk-transform-right">
      <div class="lk-page-chrome">
        <div class="lk-page-chrome-dots"><span></span><span></span><span></span></div>
        <div class="lk-page-chrome-url">heyi.am/alex/analytics-dashboard</div>
      </div>
      <div class="lk-page-body">
        <div class="lk-page-title">Real-time Analytics Dashboard</div>
        <div class="lk-page-stats-row">
          <div class="lk-page-stat-group">
            <div class="lk-page-stat-group-row">
              <div class="lk-page-stat-item"><span class="lk-page-stat-value">6h</span><span class="lk-page-stat-label">you</span></div>
              <div class="lk-page-stat-item"><span class="lk-page-stat-value">18h</span><span class="lk-page-stat-label">agents</span></div>
            </div>
            <div class="lk-page-leverage">3x leverage</div>
          </div>
          <div class="lk-page-stat-item"><span class="lk-page-stat-value">4</span><span class="lk-page-stat-label">sessions</span></div>
          <div class="lk-page-stat-item"><span class="lk-page-stat-value">2,340</span><span class="lk-page-stat-label">lines changed</span></div>
          <div class="lk-page-stat-item"><span class="lk-page-stat-value">23</span><span class="lk-page-stat-label">files</span></div>
        </div>
        <div class="lk-page-narrative-card">
          Started with a WebSocket approach but hit a wall at 10k concurrent connections. Rebuilt the pipeline around SSE after the second session. Claude kept suggesting an ORM migration that would have broken backward compat. I caught it, rolled back, and wrote the migration by hand.
        </div>
        <div class="lk-page-section-label">Agent work</div>
        <div class="lk-page-work-timeline">
          <svg viewBox="0 0 400 60" xmlns="http://www.w3.org/2000/svg">
            <circle cx="20" cy="30" r="3" fill="var(--lk-orange)"/><line x1="23" y1="30" x2="70" y2="30" stroke="var(--lk-orange)" stroke-width="2"/><circle cx="70" cy="30" r="3" fill="var(--lk-orange)"/>
            <text x="45" y="52" fill="var(--lk-text-3)" font-family="var(--font-mono)" font-size="7" text-anchor="middle">Mar 14</text>
            <line x1="75" y1="30" x2="110" y2="30" stroke="var(--lk-text-3)" stroke-width="1" stroke-dasharray="3 3" opacity="0.4"/>
            <circle cx="115" cy="30" r="4" fill="var(--lk-orange)"/>
            <path d="M 115 30 C 135 30, 135 14, 155 14 L 185 14 C 205 14, 205 30, 225 30" fill="none" stroke="var(--lk-blue)" stroke-width="1.5" opacity="0.7"/>
            <path d="M 115 30 C 140 30, 140 44, 165 44 L 175 44 C 200 44, 200 30, 225 30" fill="none" stroke="#a78bfa" stroke-width="1.5" opacity="0.7"/>
            <line x1="115" y1="30" x2="225" y2="30" stroke="var(--lk-orange)" stroke-width="2"/><circle cx="225" cy="30" r="4" fill="var(--lk-orange)"/>
            <text x="170" y="52" fill="var(--lk-text-3)" font-family="var(--font-mono)" font-size="7" text-anchor="middle">Mar 15</text>
            <line x1="230" y1="30" x2="260" y2="30" stroke="var(--lk-text-3)" stroke-width="1" stroke-dasharray="3 3" opacity="0.4"/>
            <circle cx="265" cy="30" r="4" fill="var(--lk-orange)"/>
            <path d="M 265 30 C 280 30, 280 12, 295 12 L 325 12 C 340 12, 340 30, 355 30" fill="none" stroke="#4ade80" stroke-width="1.5" opacity="0.7"/>
            <path d="M 265 30 C 285 30, 285 22, 305 22 L 315 22 C 335 22, 335 30, 355 30" fill="none" stroke="var(--lk-blue)" stroke-width="1.5" opacity="0.7"/>
            <path d="M 265 30 C 280 30, 280 40, 295 40 L 310 40 C 325 40, 325 30, 340 30" fill="none" stroke="#fbbf24" stroke-width="1.5" opacity="0.7"/>
            <line x1="265" y1="30" x2="355" y2="30" stroke="var(--lk-orange)" stroke-width="2"/><circle cx="355" cy="30" r="4" fill="var(--lk-orange)"/>
            <text x="310" y="52" fill="var(--lk-text-3)" font-family="var(--font-mono)" font-size="7" text-anchor="middle">Mar 16</text>
          </svg>
        </div>
        <div class="lk-page-section-label">Phases</div>
        <div class="lk-page-phases">
          <div class="lk-page-phase-item"><div class="lk-phase-dot lk-dot-orange"></div><div><div class="lk-phase-title">Architecture exploration</div><div class="lk-phase-desc">WebSocket prototype, load testing, discovered 10k limit</div></div></div>
          <div class="lk-page-phase-item"><div class="lk-phase-dot lk-dot-blue"></div><div><div class="lk-phase-title">SSE rebuild + migration fix</div><div class="lk-phase-desc">Caught Claude's bad ORM migration, rewrote by hand</div></div></div>
          <div class="lk-page-phase-item"><div class="lk-phase-dot lk-dot-green"></div><div><div class="lk-phase-title">Load testing + ship</div><div class="lk-phase-desc">Verified 10k concurrent, deployed to production</div></div></div>
        </div>
        <div class="lk-page-chips">
          <span>React</span><span>SSE</span><span>PostgreSQL</span><span>Architecture</span><span>Load Testing</span>
        </div>
      </div>
    </div>
  </div>
</section>

<%!-- ═══ Local-First ═══ --%>
<section class="lk-section">
  <div class="lk-section-tag">Local-first</div>
  <div class="lk-section-title">Useful before you upload anything.</div>
  <div class="lk-section-desc">No account. No data leaves your machine. Run the CLI and it starts working for you immediately.</div>

  <div class="lk-split" style="margin-top: 3rem;">
    <div class="lk-split-panel">
      <h3>The problem</h3>
      <div class="lk-split-sub">Your sessions are disappearing</div>
      <div class="lk-split-line">Claude Code deletes after 30 days</div>
      <div class="lk-split-line">Cursor stores in locked SQLite</div>
      <div class="lk-split-line">No cross-tool search</div>
      <div class="lk-split-line">No way to re-use past context</div>
    </div>
    <div class="lk-split-panel lk-split-after">
      <h3>What heyi.am does locally</h3>
      <div class="lk-split-sub">Before you ever create an account</div>
      <div class="lk-split-line"><span class="lk-hl-orange">→</span> Archives sessions permanently (hard links)</div>
      <div class="lk-split-line"><span class="lk-hl-orange">→</span> Indexes everything in local SQLite</div>
      <div class="lk-split-line"><span class="lk-hl-orange">→</span> Full-text search across all 4 tools</div>
      <div class="lk-split-line"><span class="lk-hl-orange">→</span> You vs. agent time tracking</div>
      <div class="lk-split-line"><span class="lk-hl-orange">→</span> Re-export sessions as AI context</div>
    </div>
  </div>

  <div class="lk-audience-grid" style="margin-top: 2rem; justify-content: center;">
    <div class="lk-audience-badge"><span class="lk-badge-dot"></span>No account needed</div>
    <div class="lk-audience-badge"><span class="lk-badge-dot"></span>Everything stays on your machine</div>
    <div class="lk-audience-badge"><span class="lk-badge-dot"></span>Works offline</div>
    <div class="lk-audience-badge"><span class="lk-badge-dot"></span>Portfolio when you're ready</div>
  </div>
</section>

<%!-- ═══ Built For ═══ --%>
<section class="lk-section">
  <div class="lk-section-tag">Audience</div>
  <div class="lk-section-title">Built for people who build with AI</div>
  <div class="lk-audience-grid">
    <div class="lk-audience-badge"><span class="lk-badge-dot"></span>Claude Code power users</div>
    <div class="lk-audience-badge"><span class="lk-badge-dot"></span>Cursor developers</div>
    <div class="lk-audience-badge"><span class="lk-badge-dot"></span>Codex early adopters</div>
