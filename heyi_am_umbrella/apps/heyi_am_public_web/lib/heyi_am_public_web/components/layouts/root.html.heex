<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%!-- NO csrf-token meta tag — this endpoint has no sessions --%>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />
    <title>
      <%= if assigns[:page_title] do %>
        {assigns[:page_title]} · heyi.am
      <% else %>
        heyi.am
      <% end %>
    </title>
    <%!-- Open Graph meta tags --%>
    <meta property="og:site_name" content="heyi.am" />
    <meta property="og:type" content={assigns[:og_type] || "website"} />
    <meta property="og:title" content={assigns[:og_title] || assigns[:page_title] || "heyi.am"} />
    <%= if assigns[:og_description] do %>
      <meta property="og:description" content={@og_description} />
      <meta name="description" content={@og_description} />
    <% end %>
    <%= if assigns[:og_url] do %>
      <meta property="og:url" content={@og_url} />
    <% end %>
    <meta property="og:image" content={assigns[:og_image] || HeyiAmPublicWeb.Endpoint.url() <> "/images/og-default.png"} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <%!-- Twitter Card --%>
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={assigns[:og_title] || assigns[:page_title] || "heyi.am"} />
    <%= if assigns[:og_description] do %>
      <meta name="twitter:description" content={@og_description} />
    <% end %>
    <meta name="twitter:image" content={assigns[:og_image] || HeyiAmPublicWeb.Endpoint.url() <> "/images/og-default.png"} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <%!-- NO LiveView JS — this endpoint has no LiveView --%>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
