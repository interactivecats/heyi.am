<.public_shell logo_href={"/s/#{@session.token}"} current_page="Transcript">
  <:nav_item href={"/s/#{@session.token}"} label="← Case Study" />
  <:status>
    <span class="topbar-status">{@session.turns} turns total</span>
  </:status>

  <%!-- Transcript --%>
  <div class="transcript-layout">
    <%!-- Header --%>
    <div class="transcript-header">
      <h1 class="headline-md">{@session.title}</h1>
      <div style="display: flex; gap: var(--spacing-4); flex-wrap: wrap;">
        <span class="label-mono">{if @session.recorded_at, do: Calendar.strftime(@session.recorded_at, "%b %d, %Y"), else: "—"}</span>
        <span class="label-mono">{@session.duration_minutes} min</span>
        <span class="label-mono">{@session.turns} turns</span>
      </div>
    </div>

    <%!-- Transcript Turns --%>
    <%= for {turn, idx} <- Enum.with_index(@transcript) do %>
      <% role = to_string(turn["role"]) %>
      <div class="transcript-msg">
        <div class={["transcript-avatar", role == "dev" && "transcript-avatar--dev", role == "ai" && "transcript-avatar--ai"]}>
          {if role == "dev", do: "DEV", else: "AI"}
        </div>
        <div class="transcript-content">
          <div class="transcript-meta">
            <span>{turn["id"]}</span>
            <span>{turn["timestamp"]}</span>
          </div>
          <div class="transcript-body">
            <%= for paragraph <- String.split(turn["text"] || "", "\n\n") do %>
              <p style="margin-block-end: var(--spacing-2);">{paragraph}</p>
            <% end %>
          </div>
          <%= if turn["decision"] do %>
            <% decision = turn["decision"] %>
            <div class="transcript-decision" style={if decision["color"] == "secondary", do: "border-inline-start-color: var(--secondary); background-color: rgba(0, 106, 97, 0.04);", else: ""}>
              <div class="transcript-decision-label" style={if decision["color"] == "secondary", do: "color: var(--secondary);", else: ""}>
                {decision["label"]}
              </div>
              <p class="body-sm" style={if decision["color"] == "secondary", do: "color: var(--secondary);", else: ""}>
                {decision["text"]}
              </p>
            </div>
          <% end %>
        </div>
      </div>

      <%!-- Insert "skipped turns" indicator --%>
      <%= if idx == length(@transcript) - 2 && @skipped_turns > 0 do %>
        <div style="text-align: center; padding: var(--spacing-8); color: var(--on-surface-variant); font-family: var(--font-mono); font-size: 0.8125rem;">
          ... {@skipped_turns} more turns ...
        </div>
      <% end %>
    <% end %>
  </div>
</.public_shell>
