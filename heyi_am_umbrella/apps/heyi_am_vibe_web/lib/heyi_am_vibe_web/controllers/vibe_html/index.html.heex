<div class="vibe-page vibe-index">
  <header class="vibe-hero">
    <pre class="vibe-ascii-logo" aria-hidden="true"><span class="va"> _                       _                        _  _
| |_  ___ __ __ __ _  __| |___  _  _ ___ _  ___ _(_)| |__  ___
| ' \/ _ \\ V  V // _` / _ / _ \| || / _ \ || \ V / || '_ \/ -_)
|_||_\___/ \_/\_/ \__,_\___\___/ \_, \___/\_,_|\_/|_||_.__/\___|
                                 |__/</span></pre>
    <span class="sr-only">How do you vibe?</span>
    <p class="vibe-subtitle">Find out how you work with AI coding tools.</p>
    <code class="vibe-cmd" aria-label="Run this command to get your vibe"><span class="vibe-prompt">$</span> npx howdoyouvibe</code>
    <%= if @count >= 1000 do %>
      <p class="vibe-counter">
        <strong><%= @count |> Integer.to_string() |> String.replace(~r/\B(?=(\d{3})+(?!\d))/, ",") %></strong> devs have vibed
      </p>
    <% end %>
  </header>

  <%= if @count >= 1000 and @distribution != [] do %>
    <section class="vibe-distribution" aria-labelledby="dist-heading">
      <h2 id="dist-heading">‚îÄ‚îÄ archetype breakdown ‚îÄ‚îÄ</h2>
      <nav class="vibe-dist-list" aria-label="Archetypes">
        <%= for {archetype_id, count} <- @distribution do %>
          <% meta = Map.get(@archetype_meta, archetype_id, %{name: archetype_id, tagline: ""}) %>
          <a href={~p"/archetypes/#{archetype_id}"} class="vibe-dist-item" aria-label={"#{meta.name} ‚Äî #{count} devs"}>
            <span class="vibe-dist-name"><%= meta.name %></span>
            <span class="vibe-dist-count" aria-hidden="true"><%= count %></span>
          </a>
        <% end %>
      </nav>
    </section>
  <% end %>

  <section class="vibe-preview" aria-label="Example CLI output">
    <h2 id="preview-heading">‚îÄ‚îÄ what you'll get ‚îÄ‚îÄ</h2>
    <div class="vibe-terminal">
      <div class="vibe-terminal-bar">
        <span class="vibe-terminal-dot"></span>
        <span class="vibe-terminal-dot"></span>
        <span class="vibe-terminal-dot"></span>
      </div>
      <pre class="vibe-terminal-body vibe-terminal-wide" aria-label="Example howdoyouvibe output"><span class="vc"> _                       _                        _  _
| |_  ___ __ __ __ _  __| |___  _  _ ___ _  ___ _(_)| |__  ___
| ' \/ _ \\ V  V // _` / _ / _ \| || / _ \ || \ V / || '_ \/ -_)
|_||_\___/ \_/\_/ \__,_\___\___/ \_, \___/\_,_|\_/|_||_.__/\___|
                                 |__/</span>
<span class="vd">‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê</span>

<span class="vb">The 3AM Architect who lets the AI cook</span>

You read five times more code than you write, then vanish for 200
