<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={assigns[:og_description] || "Find out how you work with AI coding tools. Run npx howdoyouvibe to get your vibe."} />
    <meta name="theme-color" content="#0a0a0f" />
    <title>
      <%= assigns[:page_title] || "HOW DO YOU VIBE?" %>
    </title>
    <%= if assigns[:og_title] do %>
      <meta property="og:title" content={@og_title} />
      <meta property="og:description" content={@og_description} />
      <meta property="og:image" content={@og_image} />
      <meta property="og:url" content={@og_url} />
      <meta property="og:type" content="website" />
      <meta name="twitter:card" content="summary_large_image" />
    <% end %>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <%= if umami_url = Application.get_env(:heyi_am, :umami_script_url) do %>
      <script defer src={umami_url} data-website-id={Application.get_env(:heyi_am_vibe_web, :umami_website_id)}></script>
    <% end %>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <main id="main-content">
      {@inner_content}
    </main>
    <footer class="vibe-site-footer">
      <span aria-hidden="true">──</span> brought to you by <a href="https://heyiam.com">heyiam.com</a> <span aria-hidden="true">──</span>
    </footer>
  </body>
</html>
