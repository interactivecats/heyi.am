<.public_shell current_page="Home">
  <:status>
    <%= if @current_scope && @current_scope.user do %>
      <span class="label-sm" style="color: var(--on-surface-variant);">
        {@current_scope.user.email}
      </span>
      <.link href={~p"/users/log-out"} method="delete" class="btn btn-secondary btn-sm">Log out</.link>
    <% else %>
      <a href={~p"/users/log-in"} class="btn btn-secondary btn-sm">Log in</a>
      <a href={~p"/users/register"} class="btn btn-primary btn-sm">Sign up</a>
    <% end %>
  </:status>

  <%!-- ── Hero ── --%>
  <section style="text-align: center; padding-block: var(--spacing-20) var(--spacing-16); max-width: 48rem; margin-inline: auto;">
    <h1 class="display-md" style="margin-block-end: var(--spacing-6);">
      The End of AI Fluff.<br /><em style="font-style: italic;">The Start of Provable Thinking.</em>
    </h1>
    <p class="body-lg" style="color: var(--on-surface-variant); max-width: 38rem; margin-inline: auto; margin-block-end: var(--spacing-8);">
      heyi.am captures your AI coding sessions, extracts the signal, and publishes cryptographically sealed case studies that prove how you actually build.
    </p>
    <div style="display: flex; gap: var(--spacing-3); justify-content: center; margin-block-end: var(--spacing-10);">
      <a href={~p"/users/register"} class="btn btn-primary">Publish your first session</a>
      <a href="#featured" class="btn btn-secondary">See examples</a>
    </div>

    <%!-- Terminal visual --%>
    <div class="terminal" style="max-width: 32rem; margin-inline: auto; text-align: start;">
      <div class="terminal-header">
        <div class="terminal-dots">
          <span class="terminal-dot terminal-dot--red"></span>
          <span class="terminal-dot terminal-dot--yellow"></span>
          <span class="terminal-dot terminal-dot--green"></span>
        </div>
        <span style="font-size: 0.625rem; color: rgba(255,255,255,0.4);">terminal</span>
      </div>
      <div class="terminal-line"><span class="terminal-prompt">$</span> heyiam open</div>
      <div class="terminal-line"><span style="color: var(--inverse-primary);">[INFO]</span> Found 3 sessions in ~/.claude/projects</div>
      <div class="terminal-line"><span class="terminal-prompt">$</span> heyiam enhance --session latest</div>
      <div class="terminal-line"><span class="terminal-success">&#10003;</span> Enhanced. Ready to publish.</div>
      <div class="terminal-line"><span class="terminal-prompt">$</span> heyiam publish --target=heyi.am</div>
      <div class="terminal-line"><span class="terminal-success">&#10003;</span> Sealed &amp; published: heyi.am/s/abc123</div>
      <div class="terminal-line"><span class="terminal-prompt">$</span> <span class="terminal-cursor"></span></div>
    </div>
  </section>

  <%!-- ── Feature Cards ── --%>
  <section style="padding-block: var(--spacing-16);">
    <div class="label-md" style="text-align: center; color: var(--primary); margin-block-end: var(--spacing-8);">How it works</div>
    <div class="landing-features-grid">
      <div class="card card-padded">
        <div class="label-md" style="color: var(--primary); margin-block-end: var(--spacing-4);">01</div>
        <h3 class="headline-sm" style="margin-block-end: var(--spacing-3);">CLI Ingestion</h3>
        <p class="body-md" style="color: var(--on-surface-variant);">
          Reads Claude Code, Cursor, and Copilot sessions directly from your machine. No copy-paste, no screenshots.
        </p>
      </div>
      <div class="card card-padded">
        <div class="label-md" style="color: var(--primary); margin-block-end: var(--spacing-4);">02</div>
        <h3 class="headline-sm" style="margin-block-end: var(--spacing-3);">AI Enhancement</h3>
        <p class="body-md" style="color: var(--on-surface-variant);">
          Extracts decisions, execution paths, and skills. Your answers to 5 anti-fluff questions ensure it sounds like you.
        </p>
      </div>
      <div class="card card-padded">
        <div class="label-md" style="color: var(--primary); margin-block-end: var(--spacing-4);">03</div>
        <h3 class="headline-sm" style="margin-block-end: var(--spacing-3);">Cryptographic Sealing</h3>
        <p class="body-md" style="color: var(--on-surface-variant);">
          Ed25519 signatures prove your sessions haven't been modified. Verifiable by anyone, owned by you.
        </p>
      </div>
    </div>
  </section>

  <%!-- ── Featured Takes ── --%>
  <section id="featured" style="padding-block: var(--spacing-16);">
    <div class="label-md" style="color: var(--primary); margin-block-end: var(--spacing-3);">Example Sessions</div>
    <h2 class="headline-lg" style="margin-block-end: var(--spacing-8);">How developers are showing their thinking</h2>
    <div class="landing-takes-grid">
      <div class="card card-padded">
        <div style="display: flex; justify-content: space-between; align-items: start; margin-block-end: var(--spacing-4);">
          <div>
            <div class="title-md" style="margin-block-end: var(--spacing-1);">Ripping out auth and rebuilding with phx.gen.auth</div>
            <div class="label-sm" style="color: var(--outline);">Sarah Chen</div>
          </div>
          <span class="badge badge--sealed">Sealed</span>
        </div>
        <p class="body-sm" style="color: var(--on-surface-variant); margin-block-end: var(--spacing-4);">
          "The existing auth was a liability. I needed phx.gen.auth's battle-tested defaults, but migrating live users meant I couldn't break sessions mid-deploy."
        </p>
        <div style="display: flex; gap: var(--spacing-2); flex-wrap: wrap; margin-block-end: var(--spacing-4);">
          <span class="chip chip--primary">Elixir</span>
          <span class="chip chip--primary">Phoenix</span>
          <span class="chip">Auth</span>
        </div>
        <div class="label-sm" style="color: var(--outline);">47 min</div>
      </div>

      <div class="card card-padded">
        <div style="display: flex; justify-content: space-between; align-items: start; margin-block-end: var(--spacing-4);">
          <div>
            <div class="title-md" style="margin-block-end: var(--spacing-1);">Building a real-time WebSocket sync engine</div>
            <div class="label-sm" style="color: var(--outline);">Marcus Rivera</div>
          </div>
          <span class="badge badge--sealed">Sealed</span>
        </div>
        <p class="body-sm" style="color: var(--on-surface-variant); margin-block-end: var(--spacing-4);">
          "CRDTs looked elegant in the paper but the edge cases around concurrent deletes nearly killed the project. Had to rethink the whole merge strategy."
        </p>
        <div style="display: flex; gap: var(--spacing-2); flex-wrap: wrap; margin-block-end: var(--spacing-4);">
          <span class="chip chip--primary">TypeScript</span>
          <span class="chip chip--primary">WebSockets</span>
          <span class="chip">CRDTs</span>
        </div>
        <div class="label-sm" style="color: var(--outline);">62 min</div>
      </div>

      <div class="card card-padded">
        <div style="display: flex; justify-content: space-between; align-items: start; margin-block-end: var(--spacing-4);">
          <div>
            <div class="title-md" style="margin-block-end: var(--spacing-1);">Migrating a monolith's CI pipeline to GitHub Actions</div>
            <div class="label-sm" style="color: var(--outline);">Aisha Patel</div>
          </div>
          <span class="badge badge--sealed">Sealed</span>
        </div>
        <p class="body-sm" style="color: var(--on-surface-variant); margin-block-end: var(--spacing-4);">
          "Jenkins had 200+ jobs and nobody understood the dependency graph. I mapped it first, then migrated in waves. The AI caught three circular deps I missed."
        </p>
        <div style="display: flex; gap: var(--spacing-2); flex-wrap: wrap; margin-block-end: var(--spacing-4);">
          <span class="chip chip--primary">DevOps</span>
          <span class="chip">CI/CD</span>
          <span class="chip">GitHub Actions</span>
        </div>
        <div class="label-sm" style="color: var(--outline);">35 min</div>
      </div>

      <div class="card card-padded">
        <div style="display: flex; justify-content: space-between; align-items: start; margin-block-end: var(--spacing-4);">
          <div>
            <div class="title-md" style="margin-block-end: var(--spacing-1);">Optimizing Postgres queries that were timing out in prod</div>
            <div class="label-sm" style="color: var(--outline);">James Okonkwo</div>
          </div>
          <span class="badge badge--sealed">Sealed</span>
        </div>
        <p class="body-sm" style="color: var(--on-surface-variant); margin-block-end: var(--spacing-4);">
          "EXPLAIN ANALYZE showed a sequential scan on 4M rows. Adding a partial index cut the query from 12s to 8ms. The AI helped me reason through the index strategy."
        </p>
        <div style="display: flex; gap: var(--spacing-2); flex-wrap: wrap; margin-block-end: var(--spacing-4);">
          <span class="chip chip--primary">PostgreSQL</span>
          <span class="chip">Performance</span>
          <span class="chip">Indexing</span>
        </div>
        <div class="label-sm" style="color: var(--outline);">28 min</div>
      </div>
    </div>
  </section>

  <%!-- ── AI Collaboration Profile ── --%>
  <section style="padding-block: var(--spacing-16);">
    <div class="label-md" style="color: var(--primary); margin-block-end: var(--spacing-3);">AI Collaboration Profile</div>
    <h2 class="headline-lg" style="margin-block-end: var(--spacing-8);">See how developers work with AI <span class="label-sm" style="color: var(--outline); font-weight: 400;">(Example Profile)</span></h2>
    <div class="card card-padded" style="max-width: 48rem;">
      <div class="stack stack--lg">
        <div>
          <div style="display: flex; justify-content: space-between; margin-block-end: var(--spacing-2);">
            <span class="title-sm">Task Scoping</span>
            <span class="label-md" style="color: var(--primary);">87%</span>
          </div>
          <div class="progress-bar">
            <div class="progress-bar-fill" style="width: 87%;"></div>
          </div>
        </div>
        <div>
          <div style="display: flex; justify-content: space-between; margin-block-end: var(--spacing-2);">
            <span class="title-sm">Active Redirection</span>
            <span class="label-md" style="color: var(--primary);">72%</span>
          </div>
          <div class="progress-bar">
            <div class="progress-bar-fill" style="width: 72%;"></div>
          </div>
        </div>
        <div>
          <div style="display: flex; justify-content: space-between; margin-block-end: var(--spacing-2);">
            <span class="title-sm">Verification</span>
            <span class="label-md" style="color: var(--primary);">94%</span>
          </div>
          <div class="progress-bar">
            <div class="progress-bar-fill" style="width: 94%;"></div>
          </div>
        </div>
        <div>
          <div style="display: flex; justify-content: space-between; margin-block-end: var(--spacing-2);">
            <span class="title-sm">Tool Orchestration</span>
            <span class="label-md" style="color: var(--primary);">65%</span>
          </div>
          <div class="progress-bar">
            <div class="progress-bar-fill" style="width: 65%;"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%!-- ── Dual Audience Section (dark) ── --%>
  <section style="background-color: var(--inverse-surface); color: var(--inverse-on-surface); margin-inline: calc(-1 * var(--spacing-6)); padding: var(--spacing-16) var(--spacing-6);">
    <div style="max-width: var(--content-max-width); margin-inline: auto;">
      <h2 class="headline-lg" style="text-align: center; margin-block-end: var(--spacing-12);">Built for two audiences</h2>
      <div class="landing-dual-grid">
        <div>
          <h3 class="headline-sm" style="margin-block-end: var(--spacing-4); color: var(--inverse-primary);">For Developers</h3>
          <ul class="stack stack--md" style="list-style: none;">
            <li class="body-md" style="color: var(--inverse-on-surface);">
              Stop writing case studies from memory. Your sessions are already recorded.
            </li>
            <li class="body-md" style="color: var(--inverse-on-surface);">
              Anti-fluff questions force you to explain the hard decisions, not summarize the easy ones.
            </li>
            <li class="body-md" style="color: var(--inverse-on-surface);">
              Cryptographic sealing means your work speaks for itself. No embellishment needed.
            </li>
            <li class="body-md" style="color: var(--inverse-on-surface);">
              Build a portfolio that shows how you think, not just what you shipped.
            </li>
          </ul>
        </div>
        <div>
          <h3 class="headline-sm" style="margin-block-end: var(--spacing-4); color: var(--inverse-primary);">For Hiring Managers</h3>
          <ul class="stack stack--md" style="list-style: none;">
            <li class="body-md" style="color: var(--inverse-on-surface);">
              See how candidates actually think through problems, not just the polished result.
            </li>
            <li class="body-md" style="color: var(--inverse-on-surface);">
              Sealed sessions can't be faked. Ed25519 signatures verify authenticity.
            </li>
            <li class="body-md" style="color: var(--inverse-on-surface);">
              AI collaboration profiles show whether a developer drives the AI or follows it.
            </li>
            <li class="body-md" style="color: var(--inverse-on-surface);">
              Replace take-home tests with real session reviews. Better signal, less candidate burden.
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <%!-- ── Bottom CTA ── --%>
  <section style="text-align: center; padding-block: var(--spacing-20);">
    <h2 class="display-sm" style="margin-block-end: var(--spacing-4);">Publish your first session</h2>
    <p class="body-lg" style="color: var(--on-surface-variant); margin-block-end: var(--spacing-8);">
      Install the CLI and show the world how you think.
    </p>
    <div class="terminal" style="max-width: 28rem; margin-inline: auto; text-align: start; margin-block-end: var(--spacing-8);">
      <div class="terminal-line"><span class="terminal-prompt">$</span> npm i -g heyiam && heyiam open</div>
    </div>
    <a href={~p"/users/register"} class="btn btn-primary">Get started</a>
  </section>
</.public_shell>
