<.public_shell logo_href={"/" <> @session.user.username} current_page="Session">
  <:nav_item href={"/" <> @session.user.username} label="Portfolio" />
  <:nav_item href="#" label="Session" />
  <:status>
    <span :if={@session.sealed} class="chip chip--primary">SEALED</span>
  </:status>

  <%!-- Case Study Layout --%>
  <div class="case-study-layout">
    <%!-- Main Column --%>
    <div class="case-study-main">
      <%!-- Breadcrumb --%>
      <div class="case-study-breadcrumb">
        <a href={"/" <> @session.user.username} class="case-study-breadcrumb-link">{@session.user.display_name}</a>
        <span class="case-study-breadcrumb-sep">/</span>
        <%= if assigns[:breadcrumb] do %>
          <a href={"/" <> @breadcrumb.username <> "/" <> @breadcrumb.project_slug} class="case-study-breadcrumb-link">{@session.project.title}</a>
        <% else %>
          <span>{@session.project.title}</span>
        <% end %>
        <span class="case-study-breadcrumb-sep">/</span>
        <span>{@session.title}</span>
      </div>

      <%!-- Title --%>
      <h1 class="case-study-title">{@session.title}</h1>

      <%!-- Stats Grid --%>
      <%
        agent_mins = case @session.agent_summary do
          %{"agents" => agents} when is_list(agents) ->
            Enum.sum(Enum.map(agents, fn a -> a["duration_minutes"] || 0 end))
          _ -> 0
        end
        total_agent_mins = (@session.duration_minutes || 0) + agent_mins
        has_agents = agent_mins > 0
      %>
      <div class="stats-strip">
        <div class="stat-card">
          <span class="stat-card-label">{if has_agents, do: "You / Agents", else: "Duration"}</span>
          <span class="stat-card-value stat-card-value--sm">
            {if has_agents, do: "#{@session.duration_minutes}m / #{total_agent_mins}m", else: "#{@session.duration_minutes}m"}
          </span>
        </div>
        <div class="stat-card">
          <span class="stat-card-label">Turns</span>
          <span class="stat-card-value stat-card-value--sm">{@session.turns}</span>
        </div>
        <div class="stat-card">
          <span class="stat-card-label">Files</span>
          <span class="stat-card-value stat-card-value--sm">{@session.files_changed}</span>
        </div>
        <div class="stat-card">
          <span class="stat-card-label">LOC Changed</span>
          <span class="stat-card-value stat-card-value--sm">{@session.loc_changed}</span>
        </div>
      </div>

      <%!-- Agent Activity / Work Timeline (in main column, like CLI) --%>
      <section :if={has_agents} class="case-study-section">
        <span class="case-study-section-label">Agent Activity</span>
        <div
          data-work-timeline-session
          data-token={@session.token}
          style="min-height: 80px; display: flex; align-items: center; justify-content: center;"
        >
          <span class="label-mono" style="color: var(--on-surface-variant);">Loading timeline…</span>
        </div>
      </section>

      <%!-- Developer Take --%>
      <section :if={@session.dev_take && @session.dev_take != ""} class="case-study-section">
        <span class="case-study-section-label">Developer Take</span>
        <blockquote class="case-study-take">{@session.dev_take}</blockquote>
      </section>

      <%!-- Context / Problem Statement --%>
      <section :if={@session.context && @session.context != ""} class="case-study-section">
        <span class="case-study-section-label">Context</span>
        <p class="case-study-context">{@session.context}</p>
      </section>

      <%!-- Applied Skills --%>
      <section :if={@session.skills != []}>
        <span class="case-study-section-label">Applied Skills</span>
        <div class="skills-row">
          <span :for={skill <- @session.skills} class="skill-chip">{skill}</span>
        </div>
      </section>

      <%!-- Session Q&A (only show pairs that have an answer) --%>
      <% answered_pairs = Enum.filter(@session.qa_pairs, & &1["answer"] && &1["answer"] != "") %>
      <section :if={answered_pairs != []} class="case-study-section">
        <span class="case-study-section-label">Session Questions</span>
        <div :for={qa <- answered_pairs} class="qa-pair">
          <div class="question">{qa["question"]}</div>
          <div class="answer">{qa["answer"]}</div>
        </div>
      </section>

      <%!-- Highlights (in main column as horizontal scroll cards, like CLI) --%>
      <section :if={@session.highlights != []} class="case-study-section">
        <span class="case-study-section-label">Highlights</span>
        <div class="case-study-highlights">
          <div :for={hl <- @session.highlights} class="case-study-highlight-card">
            <span class={[
              "case-study-highlight-step",
              hl["type"] == "pivot" && "case-study-highlight-step--pivot",
              hl["type"] == "win" && "case-study-highlight-step--win",
              hl["type"] == "insight" && "case-study-highlight-step--insight"
            ]}>
              {String.capitalize(hl["type"] || "highlight")}
            </span>
            <div class="case-study-highlight-title">{hl["title"]}</div>
            <div class="case-study-highlight-desc">{hl["description"]}</div>
          </div>
        </div>
      </section>
    </div>

    <%!-- Sidebar --%>
    <aside class="case-study-sidebar">
      <%!-- Execution Path (moved to sidebar, like CLI) --%>
      <div :if={@session.beats != []} class="sidebar-card">
        <span class="sidebar-card-label">Execution Path</span>
        <div class="case-study-exec-path">
          <div :for={{beat, _idx} <- Enum.with_index(@session.beats)} class="case-study-exec-step">
            <div class="case-study-exec-dot"></div>
            <div class="case-study-exec-content">
              <div class="case-study-exec-title">{beat["label"]}</div>
              <div :if={beat["description"]} class="case-study-exec-desc">{beat["description"]}</div>
            </div>
          </div>
        </div>
      </div>

      <%!-- Raw Log Preview (4 lines like CLI, not 10) --%>
      <% preview_lines = Enum.take(@session.transcript_excerpt, 4) %>
      <div :if={preview_lines != []} class="terminal session-log-preview">
        <div class="terminal-header">
          <span style="font-size: 0.625rem; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.4);">Raw Log</span>
        </div>
        <div :for={line <- preview_lines} class="terminal-line">
          <span :if={to_string(line["role"]) == "dev"} class="terminal-prompt">&gt; </span>
          <span :if={to_string(line["role"]) == "ai"} style="color: #60a5fa;">[AI] </span>
          {line["text"]}
        </div>
        <div style="margin-block-start: var(--spacing-2);">
          <a href={"/s/#{@session.token}/transcript"} style="font-family: var(--font-mono); font-size: 0.625rem; color: #60a5fa; text-decoration: none;">
            View full transcript &rarr;
          </a>
        </div>
      </div>

      <%!-- Source Info --%>
      <div class="sidebar-card">
        <span class="sidebar-card-label">Source Info</span>
        <div class="case-study-source-list">
          <div class="case-study-source-row">
            <span class="case-study-source-key">Source</span>
            <span class="case-study-source-val">{String.capitalize(@session.source_tool || "claude")} Code</span>
          </div>
          <div class="case-study-source-row">
            <span class="case-study-source-key">Date</span>
            <span class="case-study-source-val">{if @session.recorded_at, do: Calendar.strftime(@session.recorded_at, "%b %d, %Y"), else: "—"}</span>
          </div>
          <div class="case-study-source-row">
            <span class="case-study-source-key">Author</span>
            <span class="case-study-source-val">
              <%= if @session.user.username != "anonymous" do %>
                <a href={"/" <> @session.user.username} style="color: var(--primary); text-decoration: none;">
                  {@session.user.display_name}
                </a>
              <% else %>
                <span>{@session.user.display_name}</span>
              <% end %>
            </span>
          </div>
          <div :if={@session.verified_at} class="case-study-source-row">
            <span class="case-study-source-key">Verified</span>
            <span class="case-study-source-val">{Calendar.strftime(@session.verified_at, "%b %d, %Y")}</span>
          </div>
          <%= if has_agents do %>
            <div class="case-study-source-row">
              <span class="case-study-source-key">Type</span>
              <span class="case-study-source-val">
                <% agent_count = case @session.agent_summary do
                  %{"agents" => agents} when is_list(agents) -> length(agents)
                  _ -> 0
                end %>
                Orchestrated ({agent_count} agents)
              </span>
            </div>
          <% end %>
        </div>
      </div>
    </aside>
  </div>

  <%!-- Full-width sections below the 2-column layout --%>
  <div class="case-study-below" style="max-width: var(--content-max-width); margin-inline: auto; padding: 0 var(--spacing-8) var(--spacing-8);">

    <%!-- Work Timeline for non-agent sessions (still show if available) --%>
    <section :if={!has_agents} style="margin-block-end: var(--spacing-6);">
      <span class="case-study-section-label">Work Timeline</span>
      <div
        data-work-timeline-session
        data-token={@session.token}
        style="min-height: 80px; display: flex; align-items: center; justify-content: center;"
      >
        <span class="label-mono" style="color: var(--on-surface-variant);">Loading timeline…</span>
      </div>
    </section>

    <%!-- Collapsible: Tool Breakdown --%>
    <details :if={@session.tool_breakdown != []} class="collapsible" style="margin-block-end: var(--spacing-2);">
      <summary>
        Tool breakdown ({Enum.reduce(@session.tool_breakdown, 0, &((&1["count"] || 0) + &2))} calls)
      </summary>
      <div class="collapsible-content">
        <% max_count = if @session.tool_breakdown == [], do: 1, else: (Enum.max_by(@session.tool_breakdown, &((&1["count"] || 0)))["count"] || 1) %>
        <div :for={tool <- @session.tool_breakdown} style="display: flex; align-items: center; gap: var(--spacing-3); margin-block-end: var(--spacing-2);">
          <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--on-surface-variant); width: 7rem; text-align: end; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{tool["name"]}</span>
          <div style="flex: 1; height: 6px; background: var(--surface-container-low); border-radius: 3px; overflow: hidden;">
            <div style={"width: #{max(8, round((tool["count"] || 0) / max_count * 100))}%; height: 100%; background: var(--primary); border-radius: 3px;"}></div>
          </div>
          <span style="font-family: var(--font-mono); font-size: 0.75rem; width: 2rem;">{tool["count"]}</span>
        </div>
      </div>
    </details>

    <%!-- Collapsible: Files Changed --%>
    <details :if={@session.top_files != []} class="collapsible" style="margin-block-end: var(--spacing-2);">
      <summary>
        Files changed ({@session.files_changed} files)
      </summary>
      <div class="collapsible-content">
        <div :for={file <- @session.top_files} style="display: flex; justify-content: space-between; gap: var(--spacing-2); padding: var(--spacing-1) 0; font-family: var(--font-mono); font-size: 0.75rem;">
          <span style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0;">{file["path"]}</span>
          <span style="color: var(--on-surface-variant);">{file["touches"]}x</span>
        </div>
        <div :if={@session.files_changed > length(@session.top_files)} style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--on-surface-variant); padding: var(--spacing-2) 0;">
          ... {@session.files_changed - length(@session.top_files)} more files
        </div>
      </div>
    </details>

    <%!-- Collapsible: Turn Timeline (capped at 30 entries) --%>
    <% visible_turns = Enum.take(@session[:turn_timeline] || [], 30) %>
    <% total_turns = length(@session[:turn_timeline] || []) %>
    <details :if={visible_turns != []} class="collapsible" style="margin-block-end: var(--spacing-2);">
      <summary>
        Turn timeline ({total_turns} turns)
      </summary>
      <div class="collapsible-content">
        <div :for={turn <- visible_turns} style="display: flex; align-items: flex-start; gap: var(--spacing-3); margin-block-end: var(--spacing-3);">
          <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--on-surface-variant); min-width: 2rem; text-align: end;">
            #{turn["turn"]}
          </span>
          <div style="flex: 1;">
            <span style="font-size: 0.8125rem;">{turn["prompt"]}</span>
            <div :if={turn["tools"] && turn["tools"] != []} style="display: flex; gap: var(--spacing-1); margin-block-start: var(--spacing-1); flex-wrap: wrap;">
              <span :for={tool <- turn["tools"]} class="chip" style="font-size: 0.625rem; padding: 1px 6px;">{tool}</span>
            </div>
          </div>
        </div>
        <div :if={total_turns > 30} style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--on-surface-variant); padding: var(--spacing-2) 0;">
          ... {total_turns - 30} more turns.
          <a href={"/s/#{@session.token}/transcript"} style="color: var(--primary); text-decoration: none;">View full transcript →</a>
        </div>
      </div>
    </details>

    <%!-- Collapsible: Full Narrative --%>
    <details :if={@session.narrative && @session.narrative != ""} class="collapsible" style="margin-block-end: var(--spacing-2);">
      <summary>Full narrative</summary>
      <div class="collapsible-content" style="font-size: 0.875rem; color: var(--on-surface-variant); line-height: 1.7;">
        <p :for={paragraph <- String.split(@session.narrative, "\n\n")} style="margin-block-end: var(--spacing-4);">
          {paragraph}
        </p>
      </div>
    </details>
  </div>
</.public_shell>
